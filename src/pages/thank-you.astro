---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Thank You | 2 Smokin' Barrels">
    <main class="container" style="max-width: 600px; margin: 4rem auto; text-align: center; padding: 2rem;">
        <h1 style="color: var(--accent-red);">Message Received!</h1>
        <p style="color: var(--white-med);">Thanks for reaching out. I've received your message and will get back to you as soon as I can.</p>
        <a href="/" class="cmd-btn" style="display: inline-block; margin-top: 2rem; padding: 10px 20px;">Return Home</a>
    </main>
</Layout>