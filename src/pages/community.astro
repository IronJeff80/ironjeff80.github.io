---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Community | 2 Smokin' Barrels">
    <main class="container">
        <h1 class="page-title">Community</h1>
        <p style="text-align: center; color: var(--white-med); margin-bottom: 3rem;">
            Check out the incredible creators, channels, and friends of the community!
        </p>

        <!-- Cards Container -->
        <div class="grid" style="grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap: 30px;">
            
            <!-- Official Nugzz Crew -->
            <div class="card" style="align-items: center; text-align: center;">
                <img src="/images/community/nugzz.jpg" alt="Official Nugzz Crew" style="border-radius: 50%; width: 100px; height: 100px; border: 2px solid var(--accent-red); margin-bottom: 1rem; object-fit: cover;">
                <h3>Official Nugzz Crew</h3>
                <p style="color: var(--white-med); font-size: 0.95rem; margin-bottom: 1rem; flex-grow: 1;">
                    An amazing collective creating fantastic content. Check out their official site and latest YouTube uploads!
                </p>
                
                <!-- Stream Indicators -->
                <div style="display: flex; justify-content: center; gap: 12px; flex-wrap: wrap; margin-bottom: 1.5rem; font-size: 0.8rem; background: rgba(0,0,0,0.4); padding: 8px; border-radius: 4px; border: 1px solid #333; width: 100%; box-sizing: border-box;">
                    <span style="color: var(--white-low);">Face: <span style="color: #00ff00; font-weight: bold;">&#10003;</span></span>
                    <span style="color: var(--white-low);">Mic: <span style="color: #00ff00; font-weight: bold;">&#10003;</span></span>
                    <span style="color: var(--white-low);">Integrations: <span style="color: #00ff00; font-weight: bold;">Streamer.bot</span></span>
                </div>

                <div style="display: flex; gap: 10px; width: 100%;">
                    <a href="https://officialnugzzcrew.com/" target="_blank" class="cmd-btn" style="text-decoration: none; font-size: 0.8rem; padding: 10px; flex: 1;">Website</a>
                    <a href="https://www.youtube.com/@OfficialNugzzCrew" target="_blank" class="cmd-btn" style="text-decoration: none; font-size: 0.8rem; padding: 10px; flex: 1;">YouTube</a>
                </div>
            </div>

            <!-- Aidan Ketch -->
            <div class="card" style="align-items: center; text-align: center;">
                <img src="/images/community/aidan.jpg" alt="Aidan Ketch" style="border-radius: 50%; width: 100px; height: 100px; border: 2px solid var(--accent-red); margin-bottom: 1rem; object-fit: cover;">
                <h3>Aidan Ketch</h3>
                <p style="color: var(--white-med); font-size: 0.95rem; margin-bottom: 1rem; flex-grow: 1;">
                    Bringing you great gameplay and high-quality streaming content. Catch the newest videos over on YouTube.
                </p>
                
                <!-- Stream Indicators -->
                <div style="display: flex; justify-content: center; gap: 12px; flex-wrap: wrap; margin-bottom: 1.5rem; font-size: 0.8rem; background: rgba(0,0,0,0.4); padding: 8px; border-radius: 4px; border: 1px solid #333; width: 100%; box-sizing: border-box;">
                    <span style="color: var(--white-med);">Face: <span style="color: var(--accent-red); font-weight: bold;">&#10007;</span></span>
                    <span style="color: var(--white-low);">Mic: <span style="color: #00ff00; font-weight: bold;">&#10003;</span></span>
                    <span style="color: var(--white-med);">Integrations: <span style="color: var(--accent-red); font-weight: bold;">None</span></span>
                </div>

                <a href="https://www.youtube.com/@AidanKetch" target="_blank" class="cmd-btn" style="text-decoration: none; font-size: 0.8rem; padding: 10px; width: 100%; box-sizing: border-box;">YouTube Channel</a>
            </div>

            <!-- Leslie Cheyanne -->
            <div class="card" style="align-items: center; text-align: center;">
                <img src="/images/community/leslie.jpg" alt="Leslie Cheyanne" style="border-radius: 50%; width: 100px; height: 100px; border: 2px solid var(--accent-red); margin-bottom: 1rem; object-fit: cover;">
                <h3>Leslie Cheyanne</h3>
                <p style="color: var(--white-med); font-size: 0.95rem; margin-bottom: 1rem; flex-grow: 1;">
                    Live streaming great vibes, fun chats, and awesome gameplay. Drop by Twitch and say hello!
                </p>
                
                <!-- Stream Indicators -->
                <div style="display: flex; justify-content: center; gap: 12px; flex-wrap: wrap; margin-bottom: 1.5rem; font-size: 0.8rem; background: rgba(0,0,0,0.4); padding: 8px; border-radius: 4px; border: 1px solid #333; width: 100%; box-sizing: border-box;">
                    <span style="color: var(--white-med);">Face: <span style="color: var(--accent-red); font-weight: bold;">&#10007;</span></span>
