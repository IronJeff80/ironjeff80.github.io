            </div>

            <!-- Anne Williams -->
            <div class="card" style="align-items: center; text-align: center;">
                <img src="/images/community/anne.jpg" alt="Anne Williams" style="border-radius: 50%; width: 100px; height: 100px; border: 2px solid var(--accent-red); margin-bottom: 1rem; object-fit: cover;">
                <h3>Anne Williams</h3>
                <p style="color: var(--white-med); font-size: 0.95rem; margin-bottom: 1rem; flex-grow: 1;">
                    An incredibly welcoming stream featuring a beautiful community built on friendship.
                </p>
                
                <!-- Stream Indicators -->
                <div style="display: flex; justify-content: center; gap: 12px; flex-wrap: wrap; margin-bottom: 1.5rem; font-size: 0.8rem; background: rgba(0,0,0,0.4); padding: 8px; border-radius: 4px; border: 1px solid #333; width: 100%; box-sizing: border-box;">
                    <span style="color: var(--white-med);">Face: <span style="color: var(--accent-red); font-weight: bold;">&#10007;</span></span>
                    <span style="color: var(--white-med);">Mic: <span style="color: var(--accent-red); font-weight: bold;">&#10007;</span></span>
                    <span style="color: var(--white-low);">Integrations: <span style="color: #00ff00; font-weight: bold;">Mix-It-Up</span></span>
                </div>

                <a href="https://www.twitch.tv/anne_williamss" target="_blank" class="cmd-btn" style="text-decoration: none; font-size: 0.8rem; padding: 10px; width: 100%; box-sizing: border-box;">Twitch Channel</a>
            </div>

            <!-- Haunter -->
            <div class="card" style="align-items: center; text-align: center;">
                <img src="/images/community/haunter.jpg" alt="Haunter" style="border-radius: 50%; width: 100px; height: 100px; border: 2px solid var(--accent-red); margin-bottom: 1rem; object-fit: cover;">
