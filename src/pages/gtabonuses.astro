---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Stream Commands | 2 Smokin' Barrels">
    <main class="container" style="max-width: 1200px; margin: 0 auto; padding: 4rem 5%; text-align: center;">
        <header style="margin-bottom: 3rem;">
            <h1 style="font-family: 'RDRLino', serif; font-size: 3rem; color: var(--accent-red); margin-bottom: 10px;">Weekly Event Report</h1>
            <p class="date-range">May 21, 2026 — May 27, 2026</p>
            <div style="background: rgba(139, 0, 0, 0.1); border-left: 5px solid var(--accent-red); padding: 20px; margin-top: 20px; text-align: left;">
                <p style="margin: 0; font-size: 1.1rem;">
                    <span class="highlight-text">Motor Madness</span> continues! Earn <span class="highlight-text">2X Rewards</span> on Auto Shop Robbery Finales and complete the Weekly Challenge by winning two LS Car Meet Races to receive the <span class="highlight-text">Bright Manor Racing Suit</span> and <span class="highlight-text">GTA$100,000</span>. Also, don't miss the claimable <span class="highlight-text">Obey Omnis</span> in The Gangbanger Robbery.
                </p>
            </div>
        </header>

        <div class="bonus-grid">
            <div class="bonus-card">
                <h3>Multipliers</h3>
                <div class="bonus-item"><span class="multiplier">5X</span> <strong>LS Car Meet Rep</strong> on all LS Car Meet related activities</div>
                <div class="bonus-item"><span class="multiplier">2X</span> <strong>GTA$ & RP</strong> on Auto Shop Robbery Contract Finales</div>
                <div class="bonus-item"><span class="multiplier">2X</span> <strong>GTA$ & RP</strong> on LS Car Meet Series (Street, Pursuit, Drag & Drift Races)</div>
                <div class="bonus-item"><span class="multiplier">2X</span> <strong>GTA$ & RP</strong> on Junk Energy Time Trials (4X for GTA+ Members)</div>
                <div class="bonus-item"><span class="multiplier">2X</span> <strong>GTA$ & RP</strong> on RC Time Trials & Hotring Races</div>
            </div>

            <div class="bonus-card">
                <h3>Weekly Challenge</h3>
                <div class="bonus-item"><strong>Objective:</strong> Win 2 LS Car Meet Races</div>
                <div class="bonus-item"><strong>Reward:</strong> Bright Manor Racing Suit & GTA$100,000</div>
            </div>

            <div class="bonus-card">
                <h3>Salvage Yard Robberies</h3>
                <div class="bonus-item"><strong>The Cargo Ship Robbery:</strong> Grotti Turismo Omaggio (Top Tier)</div>
                <div class="bonus-item"><strong>The Gangbanger Robbery (CLAIMABLE):</strong> Obey Omnis with LS Car Meet vanity plate</div>
                <div class="bonus-item"><strong>The McTony Robbery:</strong> Vapid Hustler (Low Tier)</div>
                <div class="bonus-item"><strong>FIB Priority File:</strong> The Brute Force File</div>
            </div>

            <div class="bonus-card">
                <h3>Motor Madness Rewards (Through May 27)</h3>
                <div class="bonus-item">Log in to receive the <strong>Rockstar Helmet</strong></div>
                <div class="bonus-item">Purchase any vehicle from Premium Deluxe Motorsport to receive the <strong>Rockstar Racing Suit</strong> (within 72 hours)</div>
                <div class="bonus-item">Purchase any vehicle from Luxury Autos to receive the <strong>LS Customs Varsity Jacket</strong> (within 72 hours)</div>
                <div class="bonus-item">Purchase any vehicle featured in the LS Car Meet to receive the <strong>Blue Banshee Tee</strong> (within 72 hours)</div>
                <div class="bonus-item"><strong>FREE</strong> Horn Customization & LS Car Meet Membership</div>
            </div>
             
            <div class="bonus-card">
                 <h3>Discounts (50% OFF)</h3>
                 <div class="bonus-item">LS Tuners Racing Suits</div>
                 <div class="bonus-item">HSW Performance Upgrades & Benny’s Conversion Upgrades</div>
                 <div class="bonus-item">Turbo Tuning & Blue/Yellow Tire Smoke Customization</div>
                 <div class="bonus-item"><strong>Gun Van:</strong> Railgun</div>
            </div>

            <div class="bonus-card">
                <h3>Discounts (40% OFF)</h3>
                <div class="bonus-item">Auto Shop Properties, Upgrades & Modifications</div>
                <div class="bonus-item">All Small, Medium & Large Garage Properties</div>
                <div class="bonus-item">Bravado Banshee GTS / Declasse Lifeguard</div>
                <div class="bonus-item">Dewbauchee Rapid GT / Emperor Vectre</div>
                <div class="bonus-item">Enus Paragon R / Lampadati Felon GT</div>
                <div class="bonus-item">Nagasaki Hot Rod Blazer / Överflöd Entity XF</div>
                <div class="bonus-item">Übermacht Cypher</div>
            </div>

            <div class="bonus-card">
                <h3>Discounts (30% OFF)</h3>
                <div class="bonus-item">Dashound / HVY Chernobog</div>
                <div class="bonus-item">Pegassi Torero / RC Bandito</div>
                <div class="bonus-item">Vapid Desert Raid</div>
                <div class="bonus-item"><strong>Gun Van (GTA+ Members):</strong> Combat Shotgun</div>
            </div>

            <div class="bonus-card">
                <h3>Showrooms & Test Rides</h3>
                <div class="bonus-item"><strong>Premium Deluxe Motorsport:</strong> Declasse Lifeguard, Dewbauchee Rapid GT, Lampadati Felon GT, Överflöd Entity XF & Western Rat Bike</div>
                <div class="bonus-item"><strong>Luxury Autos:</strong> Progen Luiva & Shitzu Keitora</div>
                <div class="bonus-item"><strong>Podium Vehicle:</strong> Ocelot R88</div>
                <div class="bonus-item"><strong>Prize Ride:</strong> Ocelot Virtue (Place Top 3 in three Races in the LS Car Meet Series)</div>
                <div class="bonus-item"><strong>Test Track:</strong> Bravado Banshee GTS, Emperor Vectre (Xero 29 livery) & Übermacht Cypher (Negative Speed Demon livery)</div>
                <div class="bonus-item"><strong>HSW Test Ride:</strong> Übermacht Niobe</div>
            </div>
            
             <div class="bonus-card">
                <h3>Premium Race & Trials</h3>
                <div class="bonus-item"><strong>Premium Race:</strong> Criminal Records</div>
                <div class="bonus-item"><strong>Time Trial:</strong> Stab City</div>
                <div class="bonus-item"><strong>HSW Time Trial:</strong> Del Perro Beach to Murietta Heights</div>
            </div>
        </div>
        
        <div style="margin-top: 3rem;">
            <a href="/" style="color: var(--accent-red); text-decoration: none; font-weight: 600; text-transform: uppercase;">&larr; Back to Home</a>
        </div>
    </main>
</Layout>