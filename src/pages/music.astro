                    <a href="YOUR_GOOGLE_DRIVE_FOLDER_LINK_HERE" target="_blank" class="cmd-btn" style="text-decoration: none; font-size: 0.85rem; padding: 10px; width: 100%; box-sizing: border-box; text-align: center; display: block;">Download Full Album</a>
                </div>
                
                <details style="background: rgba(0,0,0,0.4); border: 1px solid #333; padding: 10px; border-radius: 4px;">
                    <summary style="color: var(--accent-red); font-weight: 600; cursor: pointer; outline: none;">View Tracks</summary>
                    <ul style="list-style: none; padding: 0; margin: 10px 0 0 0;">
                        <li style="display: flex; justify-content: space-between; align-items: center; border-top: 1px solid #222; padding: 8px 0;">
                            <span style="font-size: 0.9rem; color: var(--white-low);">1. Track Name Here</span>
