---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Community | 2 Smokin' Barrels"
        description="Check out the incredible creators, channels, and friends of the community!"
        image="https://2smokinbarrels.com/images/community-banner.jpg"
    >
    <main class="container">
        <h1 class="page-title">Community</h1>
        <p style="text-align: center; color: var(--white-med); margin-bottom: 3rem;">
            Check out the incredible creators, channels, and friends of the community!
        </p>

        <!-- ============================================== -->
        <!-- FEATURED STREAMERS                             -->
        <!-- ============================================== -->
        <h3 class="section-title" style="font-family: 'Bebas Neue', sans-serif; letter-spacing: 2px; color: var(--accent-orange); text-shadow: 0 0 8px rgba(255, 140, 27, 0.4); border-bottom: 1px solid rgba(255, 255, 255, 0.1); padding-bottom: 0.5rem; margin-bottom: 2rem;">
            Featured Creators
        </h3>
        
        <div class="grid" style="grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 30px; margin-bottom: 4rem;">
            
            <!-- Official Nugzz Crew -->
            <div class="card" style="align-items: center; text-align: center;">
                <img src="/images/community/nugzz.jpg" alt="Official Nugzz Crew" style="border-radius: 50%; width: 100px; height: 100px; border: 2px solid var(--accent-pink); box-shadow: 0 0 15px rgba(234, 72, 178, 0.4); margin-bottom: 1rem; object-fit: cover;">
                <h3 style="font-family: 'Inter', sans-serif; font-size: 1.5rem; font-weight: 600; letter-spacing: 0;">Official Nugzz Crew</h3>
                <p style="color: var(--white-med); font-size: 0.95rem; margin-bottom: 1rem; flex-grow: 1;">
                    An amazing collective creating fantastic content. Check out their official site and latest YouTube uploads!
                </p>
                
                <div style="display: flex; justify-content: center; gap: 12px; flex-wrap: wrap; margin-bottom: 1.5rem; font-size: 0.8rem; background: rgba(0,0,0,0.2); padding: 8px; border-radius: 8px; border: 1px solid rgba(255, 255, 255, 0.05); width: 100%; box-sizing: border-box;">
                    <span style="color: var(--white-low);">Face: <span style="color: #00ff00; font-weight: bold;">&#10003;</span></span>
                    <span style="color: var(--white-low);">Mic: <span style="color: #00ff00; font-weight: bold;">&#10003;</span></span>
                    <span style="color: var(--white-low);">Integrations: <span style="color: #00ff00; font-weight: bold;">Streamer.bot</span></span>
                </div>

                <div style="display: flex; gap: 10px; width: 100%;">
                    <a href="https://officialnugzzcrew.com/" target="_blank" class="cmd-btn" style="text-decoration: none; font-size: 0.8rem; padding: 10px; flex: 1;">Website</a>
                    <a href="https://www.youtube.com/@OfficialNugzzCrew" target="_blank" class="cmd-btn" style="text-decoration: none; font-size: 0.8rem; padding: 10px; flex: 1; background: rgba(255, 255, 255, 0.1); box-shadow: none; border: 1px solid rgba(255, 255, 255, 0.1);">YouTube</a>
                </div>
            </div>

            <!-- Haunter -->
            <div class="card" style="align-items: center; text-align: center;">
                <img src="/images/community/haunter.jpg" alt="Haunter" style="border-radius: 50%; width: 100px; height: 100px; border: 2px solid var(--accent-pink); box-shadow: 0 0 15px rgba(234, 72, 178, 0.4); margin-bottom: 1rem; object-fit: cover;">
                <h3 style="font-family: 'Inter', sans-serif; font-size: 1.5rem; font-weight: 600; letter-spacing: 0;">Haunter</h3>
                <p style="color: var(--white-med); font-size: 0.95rem; margin-bottom: 1rem; flex-grow: 1;">
                    Awesome content creator bringing great vibes and entertainment to the community.
