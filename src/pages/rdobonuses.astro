---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Red Dead Bonuses | 2 Smokin' Barrels">
    <main class="container">
        
        <header style="margin-bottom: 3rem;">
            <h1 class="page-title">Red Dead Monthly</h1>
            <p class="date-range" style="text-align: center; color: var(--white-med); text-transform: uppercase; font-weight: 600; letter-spacing: 1px;">June 30, 2026 — August 3, 2026[cite: 1]</p>
            
        <!-- Modernized Highlight Box -->
        <div style="background: rgba(38, 30, 62, 0.4); 
                    border-left: 5px solid var(--accent-pink); 
                    padding: 25px; 
                    margin-top: 20px; 
                    text-align: left; 
                    border-radius: 12px; 
                    backdrop-filter: blur(10px); 
                    border: 1px solid rgba(255, 255, 255, 0.05);">
                <p style="margin: 0; font-size: 1.1rem; color: var(--white-low);">
                    Earn <span style="color: var(--accent-orange); font-weight: 700;">3X RDO$, XP and Role XP</span> on Regular Bounties this month[cite: 1]. 
                    Legendary and Infamous Bounties pay out a massive <span style="color: var(--accent-pink); font-weight: 700;">3X RDO$, XP and Gold</span>[cite: 1]. 
                    Plus, enjoy a <span style="color: var(--accent-pink); font-weight: 700;">100% Posse Multiplier XP Boost</span>[cite: 1].
                </p>
            </div>
        </header>

        <div class="bonus-grid">
            <div class="bonus-card">
                <h3 style="font-family: 'Bebas Neue', sans-serif; font-size: 2rem; letter-spacing: 2px; color: var(--accent-orange); text-shadow: 0 0 8px rgba(255, 140, 27, 0.4);">Current Bonuses</h3>
                <div class="bonus-item"><span class="multiplier">3X</span> <strong>RDO$, XP & Gold</strong> on Legendary and Infamous Bounties[cite: 1]</div>
                <div class="bonus-item"><span class="multiplier">3X</span> <strong>RDO$, XP & Role XP</strong> on Regular Bounties[cite: 1]</div>
                <div class="bonus-item"><span class="multiplier">3X</span> <strong>RDO$ & XP</strong> on Day of Reckoning & Manhunt Free Roam Events[cite: 1]</div>
                <div class="bonus-item"><span class="multiplier">3X</span> <strong>RDO$ & XP</strong> on Featured Series[cite: 1]</div>
                <div class="bonus-item"><span class="multiplier">100%</span> <strong>Posse Multiplier XP Boost</strong>[cite: 1]</div>
            </div>

            <div class="bonus-card">
                <h3 style="font-family: 'Bebas Neue', sans-serif; font-size: 2rem; letter-spacing: 2px; color: var(--accent-orange); text-shadow: 0 0 8px rgba(255, 140, 27, 0.4);">Monthly Rewards</h3>
                <div class="bonus-item"><strong>Rebellion Poncho:</strong> Log in to receive[cite: 1].</div>
                <div class="bonus-item"><strong>Spirit of 1776 Bandana:</strong> Log in as a Bounty Hunter to receive[cite: 1].</div>
                <div class="bonus-item"><strong>White Rushword Shirt:</strong> Complete a Round of Day of Reckoning or Manhunt[cite: 1].</div>
                <div class="bonus-item"><strong>Asking for Trouble Emote:</strong> Complete any Bounty[cite: 1].</div>
                <div class="bonus-item"><strong>War Cry Emote:</strong> Complete a Legendary Bounty[cite: 1].</div>
                <div class="bonus-item"><strong>Green Morning Tail Coat:</strong> Complete all Bounty Hunter Daily Challenges[cite: 1].</div>
            </div>

            <div class="bonus-card">
                <h3 style="font-family: 'Bebas Neue', sans-serif; font-size: 2rem; letter-spacing: 2px; color: var(--accent-orange); text-shadow: 0 0 8px rgba(255, 140, 27, 0.4);">Weekly Rewards</h3>
                <div class="bonus-item"><span class="date-range" style="color: var(--accent-pink);">June 30 - July 6</span><br>Complete 2 Bounties: <strong>3 Hawkmoth Bolas & 100 Express Repeater Ammo</strong>[cite: 1]</div>
                <div class="bonus-item"><span class="date-range" style="color: var(--accent-pink);">July 7-13</span><br>Activity with Persistent Posse: <strong>Blue Eberhart Coat</strong>[cite: 1]</div>
                <div class="bonus-item"><span class="date-range" style="color: var(--accent-pink);">July 14-20</span><br>Purchase Weapon Mod: <strong>West Hill Haven Treasure Map</strong>[cite: 1]</div>
                <div class="bonus-item"><span class="date-range" style="color: var(--accent-pink);">July 21-27</span><br>Rank up 5x or reach Rank 20+ Bounty Hunter: <strong>Orange Raccoon Hat</strong>[cite: 1]</div>
                <div class="bonus-item"><span class="date-range" style="color: var(--accent-pink);">July 28 - Aug 3</span><br>Complete 2 Bounties: <strong>Free Weapon Reward</strong>[cite: 1]</div>
            </div>

            <div class="bonus-card">
                <h3 style="font-family: 'Bebas Neue', sans-serif; font-size: 2rem; letter-spacing: 2px; color: var(--accent-orange); text-shadow: 0 0 8px rgba(255, 140, 27, 0.4);">Featured Series</h3>
                <div class="bonus-item"><span class="date-range" style="color: var(--accent-pink);">June 30 - July 6:</span> Shootout Series[cite: 1]</div>
                <div class="bonus-item"><span class="date-range" style="color: var(--accent-pink);">July 7-13:</span> Hardcore Most Wanted[cite: 1]</div>
                <div class="bonus-item"><span class="date-range" style="color: var(--accent-pink);">July 14-20:</span> Overrun Series[cite: 1]</div>
                <div class="bonus-item"><span class="date-range" style="color: var(--accent-pink);">July 21-27:</span> Spoils of War Series[cite: 1]</div>
                <div class="bonus-item"><span class="date-range" style="color: var(--accent-pink);">July 28 - Aug 3:</span> Team Gun Rush Series[cite: 1]</div>
            </div>

            <div class="bonus-card">
                <h3 style="font-family: 'Bebas Neue', sans-serif; font-size: 2rem; letter-spacing: 2px; color: var(--accent-orange); text-shadow: 0 0 8px rgba(255, 140, 27, 0.4);">Discounts</h3>
                <div class="bonus-item"><span style="color: var(--accent-orange);">FREE:</span> Persistent Posse Setup Fee & Bounty Hunter Wagon[cite: 1]</div>
                <div class="bonus-item"><span style="color: var(--accent-orange);">5 GOLD OFF:</span> Bounty Hunter License & Prestigious Bounty Hunter License[cite: 1]</div>
                <div class="bonus-item"><span style="color: var(--accent-orange);">50% OFF:</span> Bounty Hunter Wagon Tints, Bounty Hunter Outfits, Bolas, Throwing Knives, Breton Horses, Repeaters, Repeater Style Customization, Bandoliers & Coats[cite: 1]</div>
                <div class="bonus-item"><span style="color: var(--accent-orange);">30% OFF:</span> Pamphlets for Split Point Cartridges, Express Explosive, and Incendiary Buckshot[cite: 1]</div>
            </div>

            <div class="bonus-card">
                <h3 style="font-family: 'Bebas Neue', sans-serif; font-size: 2rem; letter-spacing: 2px; color: var(--accent-orange); text-shadow: 0 0 8px rgba(255, 140, 27, 0.4);">Returning Clothing</h3>
                <ul style="list-style: none; padding: 0; margin: 0;">
                    <li class="bonus-item">Patterned Bandana[cite: 1]</li>
                    <li class="bonus-item">Porter & Macbay Jackets[cite: 1]</li>
                    <li class="bonus-item">Torranca Coat[cite: 1]</li>
                    <li class="bonus-item">Concho Pants[cite: 1]</li>
                </ul>
            </div>

            <div class="bonus-card">
                <h3 style="font-family: 'Bebas Neue', sans-serif; font-size: 2rem; letter-spacing: 2px; color: var(--accent-orange); text-shadow: 0 0 8px rgba(255, 140, 27, 0.4);">Community Outfit</h3>
                <p style="font-size: 0.8rem; font-style: italic; margin-bottom: 10px; color: var(--accent-pink);">By Historical-Stock-303[cite: 1]</p>
                <div class="bonus-item">Gamblers Hat[cite: 1]</div>
                <div class="bonus-item">Iniesta Shirtwaist (F) or Everyday Shirt (M)[cite: 1]</div>
                <div class="bonus-item">Traditional Vest & Ribbon Tie[cite: 1]</div>
                <div class="bonus-item">Duster Coat (F) or Antoine Jacket (M)[cite: 1]</div>
                <div class="bonus-item">Buckskin Pants (F) or Studded Pants (M)[cite: 1]</div>
                <div class="bonus-item">Pickett Boots[cite: 1]</div>
            </div>
        </div>
        
        <div style="margin-top: 4rem; text-align: center;">
            <a href="/" style="color: var(--accent-pink); text-decoration: none; font-weight: 600; text-transform: uppercase; letter-spacing: 1px;">&larr; Back to Home</a>
        </div>
    </main>
</Layout>