---
import Layout from '../layouts/Layout.astro';
---

<Layout title="GTA Weekly Bonuses | 2 Smokin' Barrels">
    <main class="container">
       
        <header style="margin-bottom: 3rem;">
            <h1 class="page-title">GTA Weekly Report</h1>
            <p class="date-range" style="text-align: center; color: var(--white-med); text-transform: uppercase; font-weight: 600; letter-spacing: 1px;">June 25, 2026 — July 1, 2026</p>
            
        <!-- Modernized Highlight Box -->
        <div style="background: rgba(38, 30, 62, 0.4); 
                    border-left: 5px solid var(--accent-pink); 
                    padding: 25px; 
                    margin-top: 20px; 
                    text-align: left; 
                    border-radius: 12px; 
                    backdrop-filter: blur(10px); 
                    border: 1px solid rgba(255, 255, 255, 0.05);">
                <p style="margin: 0; font-size: 1.1rem; color: var(--white-low);">
                    <span style="color: var(--accent-orange); font-weight: 700;">Acid Lab Production</span> is in full swing! Earn <span style="color: var(--accent-pink); font-weight: 700;">2X Rewards</span> on Acid Lab Sell Missions, get 40% off the Brickade 6x6 with a <span style="color: var(--accent-pink); font-weight: 700;">FREE Acid Lab installation</span>, and break into the Darnell Bros. Garment Factory to claim an incredible <span style="color: var(--accent-orange); font-weight: 700;">4X GTA$</span> on this week's Priority FIB File.
                </p>
            </div>
        </header>

        <div class="bonus-grid">
            <div class="bonus-card">
                <h3 style="font-family: 'Bebas Neue', sans-serif; font-size: 2rem; letter-spacing: 2px; color: var(--accent-orange); text-shadow: 0 0 8px rgba(255, 140, 27, 0.4);">Multipliers</h3>
                <div class="bonus-item"><span class="multiplier">4X</span> <strong>GTA$</strong> on FIB Priority File</div>
                <div class="bonus-item"><span class="multiplier">2X</span> <strong>GTA$ & RP</strong> on Acid Lab Sell Missions</div>
                <div class="bonus-item"><span class="multiplier">2X</span> <strong>GTA$ & RP</strong> on Fooligan Jobs</div>
                <div class="bonus-item"><span class="multiplier">2X</span> <strong>GTA$ & RP</strong> on Special Vehicle Races</div>
                <div class="bonus-item"><span class="multiplier">2X</span> <strong>GTA$ & RP</strong> on Community Combat Series</div>
                <div class="bonus-item"><span class="multiplier">2X</span> <strong>GTA$</strong> on standard FIB Files</div>
            </div>

            <div class="bonus-card">
                <h3 style="font-family: 'Bebas Neue', sans-serif; font-size: 2rem; letter-spacing: 2px; color: var(--accent-orange); text-shadow: 0 0 8px rgba(255, 140, 27, 0.4);">Weekly Challenge</h3>
                <div class="bonus-item"><strong>Objective:</strong> Complete three FIB Files</div>
                <div class="bonus-item"><strong>Reward:</strong> GTA$100,000</div>
            </div>

            <div class="bonus-card">
                <h3 style="font-family: 'Bebas Neue', sans-serif; font-size: 2rem; letter-spacing: 2px; color: var(--accent-orange); text-shadow: 0 0 8px rgba(255, 140, 27, 0.4);">Fine Art Collector Program</h3>
                <div class="bonus-item"><strong>Log In Reward:</strong> GTA$500,000 (within 72 hours) + Free Benefactor Turreted Limo (Sedan) from Warstock</div>
                <div class="bonus-item"><strong>Heist Reward:</strong> Complete any Heist for GTA$1,000,000 (within 72 hours) + NOOSE Outfit</div>
                <div class="bonus-item"><strong>Mansion Owners:</strong> Log in June 18-July 13 to receive special gifts when The Kortz Center Heist drops</div>
            </div>

            <div class="bonus-card">
                <h3 style="font-family: 'Bebas Neue', sans-serif; font-size: 2rem; letter-spacing: 2px; color: var(--accent-orange); text-shadow: 0 0 8px rgba(255, 140, 27, 0.4);">Free Claims & Unlocks</h3>
                <div class="bonus-item"><strong>Free Installation:</strong> MTL Brickade 6x6 Acid Lab Installation</div>
                <div class="bonus-item"><strong>Discord Rewards:</strong> Burgundy Rockstar Varsity Crewneck (Claim in #discord-rewards until July 1)</div>
            </div>

            <div class="bonus-card">
                <h3 style="font-family: 'Bebas Neue', sans-serif; font-size: 2rem; letter-spacing: 2px; color: var(--accent-orange); text-shadow: 0 0 8px rgba(255, 140, 27, 0.4);">Salvage Yard Robberies</h3>
                <div class="bonus-item"><strong>The McTony Robbery:</strong> Lampadati Tigon (Top Tier)</div>
                <div class="bonus-item"><strong>The Podium Robbery:</strong> Invetero Coquette BlackFin (Standard Tier)</div>
                <div class="bonus-item"><strong>The Gangbanger Robbery:</strong> Vapid Clique (Low Tier)</div>
                <div class="bonus-item"><strong>FIB Priority File:</strong> The Fine Art File</div>
            </div>
             
            <div class="bonus-card">
                 <h3 style="font-family: 'Bebas Neue', sans-serif; font-size: 2rem; letter-spacing: 2px; color: var(--accent-orange); text-shadow: 0 0 8px rgba(255, 140, 27, 0.4);">Discounts (40% OFF)</h3>
                 <div class="bonus-item">MTL Brickade 6x6</div>
                 <div class="bonus-item">Darnell Bros. Garment Factory</div>
            </div>

            <div class="bonus-card">
                <h3 style="font-family: 'Bebas Neue', sans-serif; font-size: 2rem; letter-spacing: 2px; color: var(--accent-orange); text-shadow: 0 0 8px rgba(255, 140, 27, 0.4);">Discounts (30% OFF)</h3>
                <div class="bonus-item">Annis Euros X32 / Annis Remus</div>
                <div class="bonus-item">Declasse Hotring Sabre / Dewbauchee Specter</div>
                <div class="bonus-item">Dinka Jester Classic / HVY Dump</div>
                <div class="bonus-item">Karin Everon / Pegassi Zorrusso</div>
                <div class="bonus-item">Pfister Comet S2 Cabrio / Vapid Flash GT</div>
            </div>

            <div class="bonus-card">
                <h3 style="font-family: 'Bebas Neue', sans-serif; font-size: 2rem; letter-spacing: 2px; color: var(--accent-orange); text-shadow: 0 0 8px rgba(255, 140, 27, 0.4);">Gun Van Primary Discounts</h3>
                <div class="bonus-item"><strong>FREE:</strong> Baseball Bat</div>
                <div class="bonus-item"><strong>50% OFF:</strong> Battle Rifle</div>
                <div class="bonus-item"><strong>30% OFF (GTA+ Members):</strong> Stun Gun</div>
            </div>

            <div class="bonus-card">
                <h3 style="font-family: 'Bebas Neue', sans-serif; font-size: 2rem; letter-spacing: 2px; color: var(--accent-orange); text-shadow: 0 0 8px rgba(255, 140, 27, 0.4);">Showrooms & Test Rides</h3>
                <div class="bonus-item"><strong>Premium Deluxe Motorsport:</strong> Declasse Tornado Rat Rod, Enus Stafford, Pegassi Esskey, Vapid Blade & Weeny Dynasty</div>
                <div class="bonus-item"><strong>Luxury Autos:</strong> Declasse Walton L35 Stock & Karin Everon RS</div>
                <div class="bonus-item"><strong>Podium Vehicle:</strong> Invetero Coquette D10</div>
                <div class="bonus-item"><strong>Prize Ride:</strong> Obey I-Wagen (Place Top 5 in LS Car Meet Series for 4 days in a row)</div>
                <div class="bonus-item"><strong>Test Track:</strong> Benefactor XLS, Declasse Tulip & Dinka Jester</div>
                <div class="bonus-item"><strong>HSW Test Ride:</strong> Maibatsu MonstroCiti</div>
            </div>
            
             <div class="bonus-card">
                <h3 style="font-family: 'Bebas Neue', sans-serif; font-size: 2rem; letter-spacing: 2px; color: var(--accent-orange); text-shadow: 0 0 8px rgba(255, 140, 27, 0.4);">Premium Race & Trials</h3>
                <div class="bonus-item"><strong>Premium Race:</strong> Senora Freeway</div>
                <div class="bonus-item"><strong>Time Trial:</strong> Elysian Island II</div>
                <div class="bonus-item"><strong>HSW Time Trial:</strong> Pacific Bluffs to Mount Gordo</div>
            </div>
        </div>
        
        <div style="margin-top: 4rem; text-align: center;">
            <a href="/" style="color: var(--accent-pink); text-decoration: none; font-weight: 600; text-transform: uppercase; letter-spacing: 1px;">&larr; Back to Home</a>
        </div>
    </main>
</Layout>