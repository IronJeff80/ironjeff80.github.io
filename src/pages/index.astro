---
import Layout from '../layouts/Layout.astro';
---

<Layout title="2 Smokin' Barrels | Stream Tools & Extensions">

    <main class="container">
    <header style="margin-bottom: 3rem;">
        <h1 class="page-title">In Smokin' We Trust</h1>

        <!-- Modernized Highlight Box -->
        <div style="background: rgba(38, 30, 62, 0.4); 
                    border-left: 5px solid var(--accent-pink); 
                    padding: 25px; 
                    margin-top: 20px; 
                    text-align: center; 
                    border-radius: 12px; 
                    backdrop-filter: blur(10px); 
                    border: 1px solid rgba(255, 255, 255, 0.05);">
            <p style="margin: 0; font-size: 1.1rem; color: var(--white-low);">
                <span style="color: var(--accent-orange); font-weight: 700;">Custom extensions and technical tools for the Red Dead & GTA community.</span>
            </p>
        </div>
    </header>

        <div>
            <h2 class="section-title" style="font-family: 'Bebas Neue', sans-serif; letter-spacing: 2px; color: var(--accent-orange); text-shadow: 0 0 8px rgba(255, 140, 27, 0.4);">Live Stream</h2>
            <div class="stream-container">
                <div class="video-wrapper" style="position: relative;">
                    <img id="offline-placeholder" src="/images/offline.png" alt="Stream is currently offline" style="width: 100%; height: 100%; object-fit: cover; display: block; position: absolute; top: 0; left: 0;">
                    <iframe id="yt-video-frame" src="https://www.youtube.com/embed/live_stream?channel=UCbflkZl3HSQVyVW153f2Z3A" allowfullscreen style="display: none; width: 100%; height: 100%; position: relative; z-index: 2;"></iframe>
                </div>
                <div class="chat-wrapper" id="chat-wrapper" style="display: none;">
                    <iframe id="yt-chat-frame" src="about:blank"></iframe>
                </div>
            </div>

            <div class="command-center" style="background: var(--card-bg); border: 1px solid rgba(255, 255, 255, 0.05); border-radius: 16px; padding: 2rem; margin-top: 2rem; backdrop-filter: blur(12px);">
                <h3 style="font-family: 'Bebas Neue', sans-serif; color: var(--accent-orange); font-size: 2.2rem; margin-top: 0; letter-spacing: 1px;">Command Center</h3>
                <p id="status-msg" style="color: var(--white-med); font-size: 0.9rem; margin-bottom: 20px;">Connecting to Streamer.bot...</p>
                
                <h4 class="collapsible-header collapsed" onclick="toggleSection(this)" style="color: var(--accent-pink); cursor: pointer; display: flex; justify-content: space-between; align-items: center; border-bottom: 1px solid rgba(255, 255, 255, 0.1); padding-bottom: 5px;">
                    Fun Stuff & Games <i class="fas fa-chevron-down transition-icon"></i>
                </h4>
                <div class="btn-grid collapsible-content collapsed">
                    <button class="cmd-btn stream-cmd" onclick="sendAction('2) Join Game (Command)')" disabled>Join Whammy</button>
                    <button class="cmd-btn stream-cmd" onclick="sendAction('Plinko 2 -  Join Game (Command)')" disabled>Join Plinko</button>
                    <button class="cmd-btn stream-cmd" onclick="sendAction('Barrel Roll')" disabled>Barrel Roll</button>
                    <button class="cmd-btn stream-cmd" onclick="sendAction('Haduken')" disabled>Haduken</button>
                    <button class="cmd-btn stream-cmd" onclick="sendAction('Shoryuken')" disabled>Shoryuken</button>
                    <button class="cmd-btn stream-cmd" onclick="sendAction('Scorpion')" disabled>Scorpion</button>
                    <button class="cmd-btn stream-cmd" onclick="sendAction('BallDrop')" disabled>BallDrop</button>
                    <button class="cmd-btn stream-cmd" onclick="sendAction('BallDrop BlackHole')" disabled>BallDrop BlackHole</button>
                    <button class="cmd-btn stream-cmd" onclick="sendAction('BallDrop Explode')" disabled>BallDrop Explode</button>
                    <button class="cmd-btn stream-cmd" onclick="sendAction('Bombs Away')" disabled>Bombs Away</button>
                    <button class="cmd-btn stream-cmd" onclick="sendAction('Skeletor')" disabled>Skeletor</button>
                    <button class="cmd-btn stream-cmd" onclick="sendAction('GTA Wasted')" disabled>GTA Wasted</button>
                </div>

                <h4 class="collapsible-header collapsed" onclick="toggleSection(this)" style="color: var(--accent-pink); cursor: pointer; display: flex; justify-content: space-between; align-items: center; border-bottom: 1px solid rgba(255, 255, 255, 0.1); padding-bottom: 5px; margin-top: 20px;">
                    Media Controls <i class="fas fa-chevron-down transition-icon"></i>
                </h4>
                <div class="media-bar collapsible-content collapsed" style="margin-top: 15px;">
                    <button class="cmd-btn media-btn stream-cmd" onclick="sendAction('Media Previous')" title="Previous" disabled><i class="fas fa-step-backward"></i></button>
                    <button class="cmd-btn media-btn stream-cmd" onclick="sendAction('Media Stop')" title="Stop" disabled><i class="fas fa-stop"></i></button>
                    <button class="cmd-btn media-btn stream-cmd" onclick="sendAction('Media Play')" title="Play" disabled><i class="fas fa-play"></i></button>
                    <button class="cmd-btn media-btn stream-cmd" onclick="sendAction('Media Pause')" title="Pause" disabled><i class="fas fa-pause"></i></button>
                    <button class="cmd-btn media-btn stream-cmd" onclick="sendAction('Media Skip')" title="Skip" disabled><i class="fas fa-step-forward"></i></button>
                </div>

                <h4 class="collapsible-header collapsed" onclick="toggleSection(this)" style="color: var(--accent-pink); cursor: pointer; display: flex; justify-content: space-between; align-items: center; border-bottom: 1px solid rgba(255, 255, 255, 0.1); padding-bottom: 5px; margin-top: 20px;">
                    Album Selection <i class="fas fa-chevron-down transition-icon"></i>
                </h4>
                <div class="btn-grid collapsible-content collapsed">
                    <button class="cmd-btn stream-cmd" onclick="sendAction('Select Album', 'Breakin')" disabled>Breakin & Scratchin</button>
                    <button class="cmd-btn stream-cmd" onclick="sendAction('Select Album', 'Careless Desires')" disabled>80s Retro Vibes </button>
                    <button class="cmd-btn stream-cmd" onclick="sendAction('Select Album', 'RDO Camp SOngs')" disabled>RDO Camp Songs</button>
                    <button class="cmd-btn stream-cmd" onclick="sendAction('Select Album', 'Halloween')" disabled>Halloween Vibes</button>
                    <button class="cmd-btn stream-cmd" onclick="sendAction('Select Album', 'Hot List')" disabled>Chat Favorites</button>
                    <button class="cmd-btn stream-cmd" onclick="sendAction('Select Album', 'Midnight Ride')" disabled>80s Driving Vibes</button>
                    <button class="cmd-btn stream-cmd" onclick="sendAction('Select Album', 'Pipa')" disabled>Orient Meditation</button>
                    <button class="cmd-btn stream-cmd" onclick="sendAction('Select Album', 'Rock')" disabled>Rock N Roll Vibes</button>
                    <button class="cmd-btn stream-cmd" onclick="sendAction('Select Album', 'Western')" disabled>Western Vibes</button>
                </div>
            </div>
        </div>

        <div>
            <h2 class="section-title" style="font-family: 'Bebas Neue', sans-serif; letter-spacing: 2px; color: var(--accent-orange); text-shadow: 0 0 8px rgba(255, 140, 27, 0.4);">Red Dead Online Glitches</h2>
            <div class="glitch-grid">
                <div class="glitch-card">
                    <h4 style="color: var(--accent-pink);">Lake Isabella COMPLETE Guide</h4>
                    <a href="https://www.youtube.com/watch?v=olP7h9B7V90" target="_blank"><img class="glitch-thumb" src="https://img.youtube.com/vi/olP7h9B7V90/hqdefault.jpg" alt="Lake Isabella Gold Glitch"></a>
                </div>
                <div class="glitch-card">
                    <h4 style="color: var(--accent-pink);">Rapid Spawn All Treasure Maps</h4>
                    <a href="https://www.youtube.com/watch?v=sf41Gy08b-I" target="_blank"><img class="glitch-thumb" src="https://img.youtube.com/vi/sf41Gy08b-I/hqdefault.jpg" alt="Red Dead Treasure Map Glitch"></a>
                </div>
                <div class="glitch-card">
                    <h4 style="color: var(--accent-pink);">Lake Isabella Gold Glitch</h4>
                    <a href="https://www.youtube.com/watch?v=puidk5oZY7o" target="_blank"><img class="glitch-thumb" src="https://img.youtube.com/vi/puidk5oZY7o/hqdefault.jpg" alt="Lake Isabella Gold Bar Glitch"></a>
                </div>
                <div class="glitch-card">
                    <h4 style="color: var(--accent-pink);">How to: Dupe Large Pelts</h4>
                    <a href="https://www.youtube.com/watch?v=R6Hcy5KiiPk" target="_blank"><img class="glitch-thumb" src="https://img.youtube.com/vi/R6Hcy5KiiPk/hqdefault.jpg" alt="Red Dead Pelt Duplication"></a>
                </div>
            </div>
        </div>

        <div>
            <h2 class="section-title" style="font-family: 'Bebas Neue', sans-serif; letter-spacing: 2px; color: var(--accent-orange); text-shadow: 0 0 8px rgba(255, 140, 27, 0.4);">Available Projects</h2>
            <div class="grid">
                <div class="card">
                    <a href="/condoreggmap/" target="_blank" rel="noopener noreferrer" style="text-decoration: none; color: inherit;">
                        <span class="badge">Tool</span>
                        <h3 style="font-family: 'Bebas Neue', sans-serif; letter-spacing: 2px; color: var(--accent-orange);">RDO Condor Egg Map</h3>
                        <div class="card-footer" style="margin-top: 0; color: var(--grey-med); font-weight: 600; text-transform: uppercase; font-size: 0.8rem;">Launch Map <i class="fas fa-external-link-alt"></i></div>
                    </a>
                    <div class="copy-link-container">
                        <input type="text" class="copy-input" value="https://2smokinbarrels.com/condoreggmap/" readonly id="map-link">
                        <button class="copy-btn" onclick="copyLink('map-link')"><i class="fas fa-copy"></i></button>
                    </div>
                </div>

                <div class="card">
                    <a href="https://github.com/IronJeff80/gtawidget" target="_blank" rel="noopener noreferrer" style="text-decoration: none; color: inherit;">
                        <span class="badge">Overlay</span>
                        <h3 style="font-family: 'Bebas Neue', sans-serif; letter-spacing: 2px; color: var(--accent-orange);">GTA OBS Widget</h3>
                        <div class="card-footer" style="margin-top: 0; color: var(--grey-med); font-weight: 600; text-transform: uppercase; font-size: 0.8rem;">Configure <i class="fas fa-external-link-alt"></i></div>
                    </a>
                    <div class="copy-link-container">
                        <input type="text" class="copy-input" value="https://2smokinbarrels.com/gtawidget/" readonly id="gta-link">
                        <button class="copy-btn" onclick="copyLink('gta-link')"><i class="fas fa-copy"></i></button>
                    </div>
                </div>

                <div class="card">
                    <a href="https://github.com/IronJeff80/reddeadoverlay" target="_blank" rel="noopener noreferrer" style="text-decoration: none; color: inherit;">
                        <span class="badge">Overlay</span>
                        <h3 style="font-family: 'Bebas Neue', sans-serif; letter-spacing: 2px; color: var(--accent-orange);">RDO Events OBS Overlay</h3>
                        <div class="card-footer" style="margin-top: 0; color: var(--grey-med); font-weight: 600; text-transform: uppercase; font-size: 0.8rem;">Configure <i class="fas fa-external-link-alt"></i></div>
                    </a>
                    <div class="copy-link-container">
                        <input type="text" class="copy-input" value="https://2smokinbarrels.com/reddeadoverlay/" readonly id="rdo-link">
                        <button class="copy-btn" onclick="copyLink('rdo-link')"><i class="fas fa-copy"></i></button>
                    </div>
                </div>
            </div>
        </div>
    </main>
</Layout>