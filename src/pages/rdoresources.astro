---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Read Dead Resources | 2 Smokin' Barrels">
    <main class="container">
        <h1 class="page-title">Red Dead Resources</h1>
        <p class="page-subtitle">Essential tools and interactive guides for navigating the frontier.</p>

        <div id="nazar-banner" class="resource-card nazar-hero" style="display: none;">
            <div class="nazar-image-container">
                <img id="nazar-image" src="" alt="Madam Nazar Location">
            </div>
            <div class="nazar-info">
                <h3>Madam Nazar's Location</h3>
                <p id="nazar-location-text">Locating the spirits...</p>
            </div>
        </div>

        <div class="resource-grid">
            <a href="https://jeanropke.github.io/RDR2CollectorsMap/" class="resource-card" target="_blank"
                rel="noopener noreferrer">
                <div class="resource-thumb" style="background-image: url('/images/thumb-collector.jpg');">
                    <i class="fa-solid fa-map-location-dot"></i>
                </div>
                <div class="resource-info">
                    <h3>RDO Collector's Map</h3>
                    <p>The definitive interactive map for locating Madam Nazar and all daily hidden collectibles across
                        the map.</p>
                </div>
            </a>

            <a href="https://jeanropke.github.io/RDOMap/" class="resource-card" target="_blank"
                rel="noopener noreferrer">
                <div class="resource-thumb" style="background-image: url('/images/thumb-rdomap.jpg');">
                    <i class="fa-solid fa-earth-americas"></i>
                </div>
                <div class="resource-info">
                    <h3>Red Dead Online Map</h3>
                    <p>A comprehensive map detailing animal spawns, dynamic events, plant locations, and other crucial
                        points of interest.</p>
                </div>
            </a>

            <a href="https://rdo-dailies.com/" class="resource-card" target="_blank" rel="noopener noreferrer">
                <div class="resource-thumb" style="background-image: url('/images/thumb-dailies.jpg');">
                    <i class="fa-solid fa-list-check"></i>
                </div>
                <div class="resource-info">
                    <h3>Red Dead Dailies</h3>
                    <p>A quick reference guide for tracking current daily challenges to maintain streaks and efficiently
                        earn gold.</p>
                </div>
            </a>

            <a href="https://tjakubowski.github.io/rdo-naturalist/" class="resource-card" target="_blank"
                rel="noopener noreferrer">
                <div class="resource-thumb" style="background-image: url('/images/thumb-naturalist.jpg');">
                    <i class="fa-solid fa-paw"></i>
                </div>
                <div class="resource-info">
                    <h3>Interactive Field Guide</h3>
                    <p>An interactive companion to help track animal samples, hunt legendary spawns, and progress the
                        Naturalist role.</p>
                </div>
            </a>
        </div>
    </main>
</Layout>