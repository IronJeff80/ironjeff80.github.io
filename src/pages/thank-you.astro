---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Thank You | 2 Smokin' Barrels">
    <main class="container" style="max-width: 600px; margin: 4rem auto; text-align: center; padding: 3rem; background: var(--card-bg); border: 1px solid rgba(255, 255, 255, 0.05); border-radius: 16px; backdrop-filter: blur(12px);">
        <h1 style="font-family: 'Mr Dafoe', cursive; font-size: 3.5rem; color: var(--accent-pink); margin-bottom: 1rem; text-shadow: 0 0 10px rgba(234, 72, 178, 0.6);">Message Received!</h1>
        <p style="color: var(--white-med); margin-bottom: 2rem;">Thanks for reaching out. I've received your message and will get back to you as soon as I can.</p>
        <a href="/" class="cmd-btn" style="text-decoration: none;">Return Home</a>
    </main>
</Layout>