---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Stream Commands | 2 Smokin' Barrels">
    <main class="container" style="max-width: 1200px; margin: 0 auto; padding: 4rem 5%; text-align: center;">
        <header style="margin-bottom: 3rem;">
            <h1 style="font-family: 'RDRLino', serif; font-size: 3rem; color: var(--accent-red); margin-bottom: 10px;">Weekly Event Report</h1>
            <p class="date-range">May 14, 2026 — May 20, 2026</p>
            <div style="background: rgba(139, 0, 0, 0.1); border-left: 5px solid var(--accent-red); padding: 20px; margin-top: 20px; text-align: left;">
                <p style="margin: 0; font-size: 1.1rem;">
                    Two weeks of <span class="highlight-text">Motor Madness</span> hit Los Santos! Earn <span class="highlight-text">4X Rewards</span> on Land Races and complete the Weekly Challenge by winning any two Races to receive the <span class="highlight-text">Dark Manor Racing Suit</span> and <span class="highlight-text">GTA$100,000</span>. Also, log in to receive the new <span class="highlight-text">Rockstar Helmet</span> and the <span class="highlight-text">Water Like livery</span> for the Vapid FMJ MK V.
                </p>
            </div>
        </header>

        <div class="bonus-grid">
            <div class="bonus-card">
                <h3>Multipliers</h3>
                <div class="bonus-item"><span class="multiplier">4X</span> <strong>GTA$ & RP</strong> on Land Races</div>
                <div class="bonus-item"><span class="multiplier">3X</span> <strong>GTA$ & RP</strong> on HSW Time Trial</div>
                <div class="bonus-item"><span class="multiplier">3X</span> <strong>GTA$ & RP</strong> on Simeon Contact Missions</div>
                <div class="bonus-item"><span class="multiplier">2X</span> <strong>GTA$ & RP</strong> on Tow Truck Service</div>
                <div class="bonus-item"><span class="multiplier">2X</span> <strong>GTA$ & RP</strong> on Community Race Series</div>
            </div>

            <div class="bonus-card">
                <h3>Weekly Challenge</h3>
                <div class="bonus-item"><strong>Objective:</strong> Win any two Races</div>
                <div class="bonus-item"><strong>Reward:</strong> Dark Manor Racing Suit & GTA$100,000</div>
            </div>

            <div class="bonus-card">
                <h3>Salvage Yard Bonuses</h3>
                <div class="bonus-item"><span class="multiplier">2X</span> <strong>GTA$</strong> on Salvage Yard Daily Income</div>
                <div class="bonus-item"><span class="multiplier">2X</span> <strong>GTA$</strong> on Robbery Target Sale & Salvage Value</div>
                <div class="bonus-item"><strong>The Podium Robbery (CLAIMABLE):</strong> Invetero Coquette D10 with LS Pounders vanity plate</div>
                <div class="bonus-item"><strong>The Gangbanger Robbery:</strong> Vapid Dominator GT</div>
                <div class="bonus-item"><strong>The Duggan Robbery:</strong> Karin Previon</div>
                <div class="bonus-item"><strong>FIB Priority File:</strong> The Black Box File</div>
            </div>

            <div class="bonus-card">
                <h3>Motor Madness Rewards & Freebies (Through May 27)</h3>
                <div class="bonus-item">Log in to receive the <strong>Rockstar Helmet</strong> & <strong>Water Like livery (Vapid FMJ MK V)</strong></div>
                <div class="bonus-item">Purchase any vehicle from Premium Deluxe Motorsport to receive the <strong>Rockstar Racing Suit</strong></div>
                <div class="bonus-item">Purchase any vehicle from Luxury Autos to receive the <strong>LS Customs Varsity Jacket</strong></div>
                <div class="bonus-item">Purchase any vehicle featured in the LS Car Meet to receive the <strong>Blue Banshee Tee</strong></div>
                <div class="bonus-item"><strong>FREE</strong> Horn Customization & LS Car Meet Membership</div>
            </div>
            
            <div class="bonus-card">
                 <h3>Discounts (50% OFF)</h3>
                 <div class="bonus-item">LS Tuners Racing Suits</div>
                 <div class="bonus-item">HSW Performance Upgrades</div>
                 <div class="bonus-item">Benny’s Conversion Upgrades</div>
                 <div class="bonus-item">Turbo Tuning & Blue/Yellow Tire Smoke Customization</div>
            </div>

            <div class="bonus-card">
                <h3>Discounts (40% OFF)</h3>
                <div class="bonus-item">Salvage Yard Properties, Upgrades & Modifications</div>
                <div class="bonus-item">Eclipse Blvd Garage</div>
                <div class="bonus-item">Bravado Banshee GTS / Canis Castigator</div>
                <div class="bonus-item">Dewbauchee JB 700 / Dewbauchee Rapid GT Cabrio</div>
                <div class="bonus-item">Grotti Itali RSX / Karin 190z</div>
                <div class="bonus-item">Lampadati Furore GT / Nagasaki Shotaro</div>
                <div class="bonus-item">Överflöd Pipistrello / Western Rat Bike</div>
                <div class="bonus-item"><strong>Gun Van:</strong> Compact EMP Launcher (40% OFF)</div>
            </div>

            <div class="bonus-card">
                <h3>Discounts (30% OFF)</h3>
                <div class="bonus-item">Bravado Gauntlet Classic</div>
                <div class="bonus-item">Coil Brawler</div>
                <div class="bonus-item">Declasse Impaler SZ</div>
                <div class="bonus-item">Lampadati Novak</div>
                <div class="bonus-item">Übermacht Rhinehart</div>
            </div>

            <div class="bonus-card">
                <h3>Showrooms & Test Rides</h3>
                <div class="bonus-item"><strong>Premium Deluxe Motorsport:</strong> Dewbauchee JB 700, Dewbauchee Rapid GT Cabrio, Karin 190z, Lampadati Furore GT & Western Rat Bike</div>
                <div class="bonus-item"><strong>Luxury Autos:</strong> Übermacht Sentinel XS4 & Vapid FMJ MK V (Water Like livery)</div>
                <div class="bonus-item"><strong>Podium Vehicle:</strong> Benefactor LM87</div>
                <div class="bonus-item"><strong>Prize Ride:</strong> Benefactor Krieger (Place Top 5 in five Races in the LS Car Meet Series)</div>
                <div class="bonus-item"><strong>Test Track:</strong> Bravado Banshee GTS, Grotti Itali RSX (Monochrome livery) & Överflöd Pipistrello (Street Camo Right livery)</div>
                <div class="bonus-item"><strong>HSW Test Ride:</strong> Weeny Issi Rally</div>
            </div>
            
             <div class="bonus-card">
                <h3>Premium Race & Trials</h3>
                <div class="bonus-item"><strong>Premium Race:</strong> The Commute</div>
                <div class="bonus-item"><strong>Time Trial:</strong> Galileo Park</div>
                <div class="bonus-item"><strong>HSW Time Trial:</strong> East Vinewood to Vespucci Beach</div>
            </div>
        </div>
        
        <div style="margin-top: 3rem;">
            <a href="/" style="color: var(--accent-red); text-decoration: none; font-weight: 600; text-transform: uppercase;">&larr; Back to Home</a>
        </div>
    </main>
</Layout>