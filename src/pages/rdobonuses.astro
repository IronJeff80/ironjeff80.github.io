---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Red Dead Bonuses | 2 Smokin' Barrels">
    <main class="container">
        
        <header style="margin-bottom: 3rem;">
            <h1 class="page-title">Red Dead Monthly</h1>
            <p class="date-range" style="text-align: center; color: var(--white-med); text-transform: uppercase; font-weight: 600; letter-spacing: 1px;">May 5, 2026 — June 1, 2026</p>
            
        <!-- Modernized Highlight Box -->
        <div style="background: rgba(38, 30, 62, 0.4); 
                    border-left: 5px solid var(--accent-pink); 
                    padding: 25px; 
                    margin-top: 20px; 
                    text-align: left; 
                    border-radius: 12px; 
                    backdrop-filter: blur(10px); 
                    border: 1px solid rgba(255, 255, 255, 0.05);">
                <p style="margin: 0; font-size: 1.1rem; color: var(--white-low);">
                    Earn <span style="color: var(--accent-orange); font-weight: 700;">3X RDO$ and 6X XP, and Role XP</span> sampling rare animals as a Naturalist this month. 
                    Naturalist Free Roam Events pay <span style="color: var(--accent-pink); font-weight: 700;">4X RDO$ and XP</span>. 
                    Races also pay <span style="color: var(--accent-pink); font-weight: 700;">4X RDO$, Gold, and XP</span>.
                </p>
            </div>
        </header>

        <div class="bonus-grid">
            <div class="bonus-card">
                <h3 style="font-family: 'Bebas Neue', sans-serif; font-size: 2rem; letter-spacing: 2px; color: var(--accent-orange); text-shadow: 0 0 8px rgba(255, 140, 27, 0.4);">Current Bonuses</h3>
                <div class="bonus-item"><span class="multiplier">4X</span> <strong>RDO$, Gold, & XP</strong> on Races</div>
                <div class="bonus-item"><span class="multiplier">4X</span> <strong>RDO$ & XP</strong> on Wildlife Photography</div>
                <div class="bonus-item"><span class="multiplier">4X</span> <strong>RDO$ & XP</strong> on Wild Animal Kills</div>
                <div class="bonus-item"><span class="multiplier">6X</span> <strong>RDO$, XP & Role XP</strong> on Sample Sales</div>
                <div class="bonus-item"><span class="multiplier">3X</span> <strong>RDO$ & XP</strong> on Featured Series</div>
            </div>

            <div class="bonus-card">
                <h3 style="font-family: 'Bebas Neue', sans-serif; font-size: 2rem; letter-spacing: 2px; color: var(--accent-orange); text-shadow: 0 0 8px rgba(255, 140, 27, 0.4);">Monthly Rewards</h3>
                <div class="bonus-item"><strong>Black Rushword Shirt:</strong> Log in to receive.</div>
                <div class="bonus-item"><strong>Chicken Emote:</strong> Complete an Animal Sighting Mission.</div>
                <div class="bonus-item"><strong>Brown Clairborn Coat:</strong> Hunt or Sample a Legendary Animal.</div>
                <div class="bonus-item"><strong>Ruby Buckle:</strong> Place Top 3 in a Race.</div>
                <div class="bonus-item"><strong>Blue Guerra Poncho:</strong> Complete Wildlife Photography.</div>
            </div>

            <div class="bonus-card">
                <h3 style="font-family: 'Bebas Neue', sans-serif; font-size: 2rem; letter-spacing: 2px; color: var(--accent-orange); text-shadow: 0 0 8px rgba(255, 140, 27, 0.4);">Weekly Rewards</h3>
                <div class="bonus-item"><span class="date-range" style="color: var(--accent-pink);">May 5-11</span><br>Win Featured Series: <strong>2 Gold Bars</strong></div>
                <div class="bonus-item"><span class="date-range" style="color: var(--accent-pink);">May 12-18</span><br>3 Daily Challenges: <strong>50% Off Naturalist Item</strong></div>
                <div class="bonus-item"><span class="date-range" style="color: var(--accent-pink);">May 19-25</span><br>Win Featured Series: <strong>Free Emote</strong></div>
                <div class="bonus-item"><span class="date-range" style="color: var(--accent-pink);">May 26-June 1</span><br>Sell 3 Samples: <strong>Black Morning Tail Coat</strong></div>
            </div>

            <div class="bonus-card">
                <h3 style="font-family: 'Bebas Neue', sans-serif; font-size: 2rem; letter-spacing: 2px; color: var(--accent-orange); text-shadow: 0 0 8px rgba(255, 140, 27, 0.4);">Discounts</h3>
                <div class="bonus-item"><span style="color: var(--accent-orange);">FREE:</span> Sedative Ammo</div>
                <div class="bonus-item"><span style="color: var(--accent-orange);">10 GOLD OFF:</span> Sample Kit</div>
                <div class="bonus-item"><span style="color: var(--accent-orange);">50% OFF:</span> Naturalist Outfits, Pamphlets, Bows</div>
                <div class="bonus-item"><span style="color: var(--accent-orange);">40% OFF:</span> Horses, Saddles, Hats, Chaps, Off-Hand Holsters</div>
            </div>

            <div class="bonus-card">
                <h3 style="font-family: 'Bebas Neue', sans-serif; font-size: 2rem; letter-spacing: 2px; color: var(--accent-orange); text-shadow: 0 0 8px rgba(255, 140, 27, 0.4);">Returning Clothing</h3>
                <ul style="list-style: none; padding: 0; margin: 0;">
                    <li class="bonus-item">Manteca Hat</li>
                    <li class="bonus-item">Benbow Jacket</li>
                    <li class="bonus-item">Morning Tail Coat</li>
                    <li class="bonus-item">Carver Pants</li>
                    <li class="bonus-item">Salter Shoes</li>
                </ul>
            </div>

            <div class="bonus-card">
                <h3 style="font-family: 'Bebas Neue', sans-serif; font-size: 2rem; letter-spacing: 2px; color: var(--accent-orange); text-shadow: 0 0 8px rgba(255, 140, 27, 0.4);">Community Outfit</h3>
                <p style="font-size: 0.8rem; font-style: italic; margin-bottom: 10px; color: var(--accent-pink);">By allieeeeeeeeeeeeeee</p>
                <div class="bonus-item">Western Homburg Hat</div>
                <div class="bonus-item">Everyday Shirt / Iniesta Shirtwaist</div>
                <div class="bonus-item">Ribbon Tie & Paisley Vest</div>
                <div class="bonus-item">Padded Saddle Work Pants</div>
                <div class="bonus-item">Sportsman's Boots</div>
            </div>
        </div>
        
        <div style="margin-top: 4rem; text-align: center;">
            <a href="/" style="color: var(--accent-pink); text-decoration: none; font-weight: 600; text-transform: uppercase; letter-spacing: 1px;">&larr; Back to Home</a>
        </div>
    </main>
</Layout>