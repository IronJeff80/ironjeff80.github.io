                    <h4 style="font-family: 'Inter', sans-serif; font-weight: 600; text-transform: uppercase; color: var(--accent-orange); margin: 10px 0 10px 0; font-size: 1.1rem; letter-spacing: 1px; text-shadow: 0 0 8px rgba(255, 140, 27, 0.4);">Nicknames</h4>
