---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Read Dead Bonuses | 2 Smokin' Barrels">
    <main class="container" style="max-width: 1200px; margin: 0 auto; padding: 4rem 5%; text-align: center;">
        <header style="margin-bottom: 3rem;">
            <h1 style="font-family: 'RDRLino', serif; font-size: 3rem; color: var(--accent-red); margin-bottom: 10px;">Monthly Event Report</h1>
            <p class="date-range">May 5, 2026 — June 1, 2026</p>
            <div style="background: rgba(139, 0, 0, 0.1); border-left: 5px solid var(--accent-red); padding: 20px; margin-top: 20px; text-align: left;">
                <p style="margin: 0; font-size: 1.1rem;">
                    Earn <span class="highlight-text">3X RDO$ and 6X XP, and Role XP</span> sampling rare animals as a Naturalist this month. 
                    Naturalist Free Roam Events pay <span class="highlight-text">4X RDO$ and XP</span>. 
                    Races also pay <span class="highlight-text">4X RDO$, Gold, and XP</span>.
                </p>
            </div>
        </header>

        <div class="bonus-grid">
            <div class="bonus-card">
                <h3>Current Bonuses</h3>
                <div class="bonus-item"><span class="multiplier">4X</span> <strong>RDO$, Gold, & XP</strong> on Races</div>
                <div class="bonus-item"><span class="multiplier">4X</span> <strong>RDO$ & XP</strong> on Wildlife Photography</div>
                <div class="bonus-item"><span class="multiplier">4X</span> <strong>RDO$ & XP</strong> on Wild Animal Kills</div>
                <div class="bonus-item"><span class="multiplier">6X</span> <strong>RDO$, XP & Role XP</strong> on Sample Sales</div>
                <div class="bonus-item"><span class="multiplier">3X</span> <strong>RDO$ & XP</strong> on Featured Series</div>
            </div>

            <div class="bonus-card">
                <h3>Monthly Rewards</h3>
                <div class="bonus-item"><strong>Black Rushword Shirt:</strong> Log in to receive.</div>
                <div class="bonus-item"><strong>Chicken Emote:</strong> Complete an Animal Sighting Mission.</div>
                <div class="bonus-item"><strong>Brown Clairborn Coat:</strong> Hunt or Sample a Legendary Animal.</div>
                <div class="bonus-item"><strong>Ruby Buckle:</strong> Place Top 3 in a Race.</div>
                <div class="bonus-item"><strong>Blue Guerra Poncho:</strong> Complete Wildlife Photography.</div>
            </div>

            <div class="bonus-card">
                <h3>Weekly Rewards</h3>
                <div class="bonus-item">
                    <span class="date-range">May 5-11</span><br>Win Featured Series: <strong>2 Gold Bars</strong>
                </div>
                <div class="bonus-item">
                    <span class="date-range">May 12-18</span><br>3 Daily Challenges: <strong>50% Off Naturalist Item</strong>
                </div>
                <div class="bonus-item">
                    <span class="date-range">May 19-25</span><br>Win Featured Series: <strong>Free Emote</strong>
                </div>
                <div class="bonus-item">
                    <span class="date-range">May 26-June 1</span><br>Sell 3 Samples: <strong>Black Morning Tail Coat</strong>
                </div>
            </div>

            <div class="bonus-card">
                <h3>Discounts</h3>
                <div class="bonus-item"><span class="highlight-text">FREE:</span> Sedative Ammo</div>
                <div class="bonus-item"><span class="highlight-text">10 GOLD OFF:</span> Sample Kit</div>
                <div class="bonus-item"><span class="highlight-text">50% OFF:</span> Naturalist Outfits, Pamphlets, Bows</div>
                <div class="bonus-item"><span class="highlight-text">40% OFF:</span> Horses, Saddles, Hats, Chaps, Off-Hand Holsters</div>
            </div>

            <div class="bonus-card">
                <h3>Returning Clothing</h3>
                <ul style="list-style: none; padding: 0; margin: 0;">
                    <li class="bonus-item">Manteca Hat</li>
                    <li class="bonus-item">Benbow Jacket</li>
                    <li class="bonus-item">Morning Tail Coat</li>
                    <li class="bonus-item">Carver Pants</li>
                    <li class="bonus-item">Salter Shoes</li>
                </ul>
            </div>

            <div class="bonus-card">
                <h3>Community Outfit</h3>
                <p style="font-size: 0.8rem; font-style: italic; margin-bottom: 10px;">By allieeeeeeeeeeeeeee</p>
                <div class="bonus-item">Western Homburg Hat</div>
                <div class="bonus-item">Everyday Shirt / Iniesta Shirtwaist</div>
                <div class="bonus-item">Ribbon Tie & Paisley Vest</div>
                <div class="bonus-item">Padded Saddle Work Pants</div>
                <div class="bonus-item">Sportsman's Boots</div>
            </div>
        </div>
        
        <div style="margin-top: 3rem;">
            <a href="/" style="color: var(--accent-red); text-decoration: none; font-weight: 600; text-transform: uppercase;">&larr; Back to Home</a>
        </div>
    </main>
</Layout>