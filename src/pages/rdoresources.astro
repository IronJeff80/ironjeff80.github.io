---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Red Dead Resources | 2 Smokin' Barrels">
    <main class="container">
        <h1 class="page-title">Red Dead Resources</h1>
        <p class="page-subtitle" style="text-align: center; color: var(--white-med); margin-bottom: 3rem;">
            Essential tools and interactive guides for navigating the frontier.
        </p>

        {/* Updated "Widget" style for Madam Nazar tracker */}
        <div id="nazar-banner" class="resource-card nazar-hero" style="display: none; width: 90%; margin: 0 auto 3rem auto; border: 1px solid var(--accent-pink); border-radius: 16px; box-shadow: 0 0 15px rgba(234, 72, 178, 0.2);">
            <div class="nazar-image-container">
                <img id="nazar-image" src="" alt="Madam Nazar Location" style="width: 100%; height: 100%; object-fit: cover;">
            </div>
            <div class="nazar-info">
                <h3 style="font-family: 'Bebas Neue', sans-serif; font-size: 2rem; color: var(--accent-orange); margin-bottom: 10px; text-shadow: 0 0 8px rgba(255, 140, 27, 0.4);">Madam Nazar's Location</h3>
                <p id="nazar-location-text" style="color: var(--white-low);">Locating the spirits...</p>
            </div>
        </div>

        <div class="resource-grid">
            <a href="https://jeanropke.github.io/RDR2CollectorsMap/" class="resource-card" target="_blank" rel="noopener noreferrer">
                <div class="resource-thumb" style="background-image: url('/images/thumb-collector.jpg');"></div>
                <div class="resource-info">
                    <h3 style="font-family: 'Bebas Neue', sans-serif; font-size: 1.8rem; letter-spacing: 2px; color: var(--accent-orange); margin-bottom: 0.5rem; text-shadow: 0 0 8px rgba(255, 140, 27, 0.4);">RDO Collector's Map</h3>
                    <p style="color: var(--white-med);">The definitive interactive map for locating Madam Nazar and all daily hidden collectibles across the map.</p>
                </div>
            </a>

            <a href="https://jeanropke.github.io/RDOMap/" class="resource-card" target="_blank" rel="noopener noreferrer">
                <div class="resource-thumb" style="background-image: url('/images/thumb-rdomap.jpg');"></div>
                <div class="resource-info">
                    <h3 style="font-family: 'Bebas Neue', sans-serif; font-size: 1.8rem; letter-spacing: 2px; color: var(--accent-orange); margin-bottom: 0.5rem; text-shadow: 0 0 8px rgba(255, 140, 27, 0.4);">Red Dead Online Map</h3>
                    <p style="color: var(--white-med);">A comprehensive map detailing animal spawns, dynamic events, plant locations, and other crucial points of interest.</p>
                </div>
            </a>

            <a href="https://rdo-dailies.com/" class="resource-card" target="_blank" rel="noopener noreferrer">
                <div class="resource-thumb" style="background-image: url('/images/thumb-dailies.jpg');"></div>
                <div class="resource-info">
                    <h3 style="font-family: 'Bebas Neue', sans-serif; font-size: 1.8rem; letter-spacing: 2px; color: var(--accent-orange); margin-bottom: 0.5rem; text-shadow: 0 0 8px rgba(255, 140, 27, 0.4);">Red Dead Dailies</h3>
                    <p style="color: var(--white-med);">A quick reference guide for tracking current daily challenges to maintain streaks and efficiently earn gold.</p>
                </div>
            </a>

            <a href="https://tjakubowski.github.io/rdo-naturalist/" class="resource-card" target="_blank" rel="noopener noreferrer">
                <div class="resource-thumb" style="background-image: url('/images/thumb-naturalist.jpg');"></div>
                <div class="resource-info">
                    <h3 style="font-family: 'Bebas Neue', sans-serif; font-size: 1.8rem; letter-spacing: 2px; color: var(--accent-orange); margin-bottom: 0.5rem; text-shadow: 0 0 8px rgba(255, 140, 27, 0.4);">Interactive Field Guide</h3>
                    <p style="color: var(--white-med);">An interactive companion to help track animal samples, hunt legendary spawns, and progress the Naturalist role.</p>
                </div>
            </a>

            <a href="https://rdr2map.com/" class="resource-card" target="_blank" rel="noopener noreferrer">
                <div class="resource-thumb" style="background-image: url('/images/thumb-rdr2map.jpg');"></div>
                <div class="resource-info">
                    <h3 style="font-family: 'Bebas Neue', sans-serif; font-size: 1.8rem; letter-spacing: 2px; color: var(--accent-orange); margin-bottom: 0.5rem; text-shadow: 0 0 8px rgba(255, 140, 27, 0.4);">RDR2 Stroy Map</h3>
                    <p style="color: var(--white-med);">Interactive Map of Red Dead Redemption 2 Locations. Find weapons, easter eggs, collectibles and more! Use the progress tracker to find everything you need!</p>
                </div>
            </a>
        </div>
        
        <div style="margin-top: 4rem; text-align: center;">
            <a href="/" style="color: var(--accent-pink); text-decoration: none; font-weight: 600; text-transform: uppercase; letter-spacing: 1px;">&larr; Back to Home</a>
        </div>
    </main>
</Layout>