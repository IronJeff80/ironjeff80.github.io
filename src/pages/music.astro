---

<Layout title="Royalty Free Music | 2 Smokin' Barrels">
    <main class="container">
        <h1 class="page-title">Royalty Free Music</h1>
        <p style="text-align: center; color: var(--white-med); margin-bottom: 3rem;">
            Download and use these royalty-free instrumental tracks and stems for your streams and content. 
        </p>

        <!-- Albums Grid -->
        <div class="grid" style="grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 30px;">
            
            <!-- Map through the albums array to generate cards -->
            {albums.map((album) => (
                <div class="card">
                    <h3>{album.title}</h3>
                    <span class="badge" style="background: #444;">{album.genre}</span>
                    <p style="color: var(--white-med); font-size: 0.95rem; margin-bottom: 1.5rem; flex-grow: 1;">
                        {album.description}
                    </p>
                    <div style="margin-bottom: 1rem;">
                        <a href="#" target="_blank" class="cmd-btn" style="text-decoration: none; font-size: 0.85rem; padding: 10px; width: 100%; box-sizing: border-box; text-align: center; display: block;">
                            Google Drive Folder
                        </a>
                    </div>
                    
                    <details style="background: rgba(0,0,0,0.4); border: 1px solid #333; padding: 10px; border-radius: 4px;">
                        <summary style="color: var(--accent-red); font-weight: 600; cursor: pointer; outline: none;">
                            View Tracks ({album.tracks.length})
                        </summary>
                        <ul style="list-style: none; padding: 0; margin: 10px 0 0 0;">
                            {album.tracks.map((track, index) => (
                                <li style="display: flex; justify-content: space-between; align-items: center; border-top: 1px solid #222; padding: 8px 0;">
                                    <span style="font-size: 0.9rem; color: var(--white-low);">{index + 1}. {track.replace('.mp3', '')}</span>
                                </li>
                            ))}
                        </ul>
                    </details>
                </div>
            ))}

        </div>
        
        <div style="margin-top: 3rem; text-align: center;">
            <a href="/" style="color: var(--accent-red); text-decoration: none; font-weight: 600; text-transform: uppercase;">&larr; Back to Home</a>
        </div>
    </main>
</Layout>