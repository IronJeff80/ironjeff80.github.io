---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Stream Apps & Tools | 2 Smokin' Barrels">
    <main class="container">
        <h1 class="page-title">Stream Apps & Tools</h1>
        <p style="text-align: center; color: var(--white-med); margin-bottom: 3rem;">
            Explore custom overlays, widgets, and powerful streaming tools to level up your broadcast.
        </p>

        <!-- ============================================== -->
        <!-- SECTION 1: FEATURED APPS                       -->
        <!-- ============================================== -->

         <!-- Subheading for Software Programs -->
        <h3 class="section-title" style="font-family: 'Bebas Neue', sans-serif; letter-spacing: 2px; color: var(--accent-orange); text-shadow: 0 0 8px rgba(255, 140, 27, 0.4); border-bottom: 1px solid rgba(255, 255, 255, 0.1); padding-bottom: 0.5rem; margin-bottom: 2rem;">
            Featured Overlays
        </h3>

        <div class="grid" style="grid-template-columns: repeat(auto-fit, minmax(350px, 1fr)); gap: 30px; margin-bottom: 5rem;">
            
            <!-- GTA Widget Card -->
            <div class="card" style="padding: 2rem; display: flex; flex-direction: column;">
                <span class="badge">Stream Widget</span>
                <h3 style="font-family: 'Inter', sans-serif; font-size: 1.5rem; font-weight: 600; letter-spacing: 0;">GTA Weather and Event Widget</h3>
                <p style="color: var(--white-med); font-size: 0.95rem; margin-bottom: 1.5rem; flex-grow: 1;">
                    An OBS overlay that displays the current time and weather along with any limited Time Active Events such as Stoner Survival and Bigfoot Peyote.
                </p>
                <div style="display: flex; gap: 10px; width: 100%;">
                    <a href="https://2smokinbarrels.com/gtawidget/" target="_blank" class="cmd-btn" style="text-decoration: none; font-size: 0.85rem; padding: 10px; flex: 1; text-align: center;">Browser URL</a>
                    <a href="https://github.com/IronJeff80/gtawidget" target="_blank" class="cmd-btn" style="text-decoration: none; font-size: 0.85rem; padding: 10px; flex: 1; text-align: center; background: rgba(255, 255, 255, 0.1); box-shadow: none; border: 1px solid rgba(255, 255, 255, 0.1);">Documentation</a>
                </div>
            </div>

            <!-- Red Dead Overlay Widget Card -->
            <div class="card" style="padding: 2rem; display: flex; flex-direction: column;">
                <span class="badge">Stream Overlay</span>
                <h3 style="font-family: 'Inter', sans-serif; font-size: 1.5rem; font-weight: 600; letter-spacing: 0;">Red Dead Events Overlay</h3>
                <p style="color: var(--white-med); font-size: 0.95rem; margin-bottom: 1.5rem; flex-grow: 1;">
                    An OBS overlay that displays Free Mode Events 10 minutes before each event starts. Designed to look exactly like the in game toast for FM Events.
                </p>
                <div style="display: flex; gap: 10px; width: 100%;">
                    <a href="https://2smokinbarrels.com/reddeadoverlay/" target="_blank" class="cmd-btn" style="text-decoration: none; font-size: 0.85rem; padding: 10px; flex: 1; text-align: center;">Browser URL</a>
                    <a href="https://github.com/IronJeff80/reddeadoverlay" target="_blank" class="cmd-btn" style="text-decoration: none; font-size: 0.85rem; padding: 10px; flex: 1; text-align: center; background: rgba(255, 255, 255, 0.1); box-shadow: none; border: 1px solid rgba(255, 255, 255, 0.1);">Documentation</a>
                </div>
            </div>

        </div>

        <!-- ============================================== -->
        <!-- SECTION 2: PROGRAMS & CREATORS                 -->
        <!-- ============================================== -->

        <!-- Subheading for Software Programs -->
        <h3 class="section-title" style="font-family: 'Bebas Neue', sans-serif; letter-spacing: 2px; color: var(--accent-orange); text-shadow: 0 0 8px rgba(255, 140, 27, 0.4); border-bottom: 1px solid rgba(255, 255, 255, 0.1); padding-bottom: 0.5rem; margin-bottom: 2rem;">
            Streaming Programs
        </h3>

        <!-- Programs Grid -->
        <div class="grid" style="grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 30px; margin-bottom: 4rem;">
            
            <!-- Streamer.Bot -->
            <div class="card" style="align-items: center; text-align: center; padding: 2rem;">
                <img src="/images/apps/streamerbot.png" alt="Streamer.Bot" style="width: 80px; height: 80px; object-fit: contain; margin-bottom: 1rem;">
                <h3 style="font-family: 'Inter', sans-serif; font-size: 1.5rem; font-weight: 600; letter-spacing: 0;">Streamer.Bot</h3>
                <p style="color: var(--white-med); font-size: 0.9rem; margin-bottom: 1.5rem; flex-grow: 1;">
                    The ultimate automation and integration tool for live streamers. Take full control of your broadcast with powerful C# scripting and macro logic.
                </p>
                <div style="display: flex; gap: 10px; width: 100%;">
                    <a href="https://streamer.bot/" target="_blank" class="cmd-btn" style="text-decoration: none; font-size: 0.8rem; padding: 10px; flex: 1;">Website</a>
                    <a href="https://streamer.bot/downloads" target="_blank" class="cmd-btn" style="text-decoration: none; font-size: 0.8rem; padding: 10px; flex: 1; background: rgba(255, 255, 255, 0.1); box-shadow: none; border: 1px solid rgba(255, 255, 255, 0.1);">Download</a>
                </div>
            </div>

            <!-- Speaker.Bot -->
            <div class="card" style="align-items: center; text-align: center; padding: 2rem;">
                <img src="/images/apps/speakerbot.png" alt="Speaker.Bot" style="width: 80px; height: 80px; object-fit: contain; margin-bottom: 1rem;">
                <h3 style="font-family: 'Inter', sans-serif; font-size: 1.5rem; font-weight: 600; letter-spacing: 0;">Speaker.Bot</h3>
                <p style="color: var(--white-med); font-size: 0.9rem; margin-bottom: 1.5rem; flex-grow: 1;">
                    Advanced Text-to-Speech management designed to interface seamlessly with your channel rewards, voices, and bot automation triggers.
                </p>
                <div style="display: flex; gap: 10px; width: 100%;">
                    <a href="https://speaker.bot/" target="_blank" class="cmd-btn" style="text-decoration: none; font-size: 0.8rem; padding: 10px; flex: 1;">Website</a>
                    <a href="https://speaker.bot/get-started/installation" target="_blank" class="cmd-btn" style="text-decoration: none; font-size: 0.8rem; padding: 10px; flex: 1; background: rgba(255, 255, 255, 0.1); box-shadow: none; border: 1px solid rgba(255, 255, 255, 0.1);">Download</a>
                </div>
            </div>

            <!-- VoiceMod -->
            <div class="card" style="align-items: center; text-align: center; padding: 2rem;">
                <img src="/images/apps/voicemod.png" alt="VoiceMod" style="width: 80px; height: 80px; object-fit: contain; margin-bottom: 1rem;">
                <h3 style="font-family: 'Inter', sans-serif; font-size: 1.5rem; font-weight: 600; letter-spacing: 0;">VoiceMod</h3>
                <p style="color: var(--white-med); font-size: 0.9rem; margin-bottom: 1.5rem; flex-grow: 1;">
                    Real-time AI voice changer and soundboard software to bring immersive audio experiences and instant custom reactions straight to your stream audience.
                </p>
                <div style="display: flex; gap: 10px; width: 100%;">
                    <a href="https://www.voicemod.net/" target="_blank" class="cmd-btn" style="text-decoration: none; font-size: 0.8rem; padding: 10px; flex: 1;">Website</a>
                    <a href="https://account.voicemod.net/#/?action=download" target="_blank" class="cmd-btn" style="text-decoration: none; font-size: 0.8rem; padding: 10px; flex: 1; background: rgba(255, 255, 255, 0.1); box-shadow: none; border: 1px solid rgba(255, 255, 255, 0.1);">Download</a>
                </div>
            </div>

        </div>

        <!-- Subheading for Integration Creators -->
        <h3 class="section-title" style="font-family: 'Bebas Neue', sans-serif; letter-spacing: 2px; color: var(--accent-orange); text-shadow: 0 0 8px rgba(255, 140, 27, 0.4); border-bottom: 1px solid rgba(255, 255, 255, 0.1); padding-bottom: 0.5rem; margin-bottom: 2rem;">
            Integration Creators
        </h3>

        <!-- Creators Grid -->
        <div class="grid" style="grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 30px; margin-bottom: 4rem;">
            
            <!-- Tawmae -->
            <div class="card" style="align-items: center; text-align: center; padding: 2rem; display: flex; flex-direction: column;">
                <img src="/images/apps/tawmae.jpg" alt="Tawmae" style="width: 80px; height: 80px; border-radius: 50%; border: 2px solid var(--accent-pink); box-shadow: 0 0 15px rgba(234, 72, 178, 0.4); object-fit: cover; margin-bottom: 1rem;">
                <h3 style="font-family: 'Inter', sans-serif; font-size: 1.5rem; font-weight: 600; letter-spacing: 0;">Tawmae</h3>
                <p style="color: var(--white-med); font-size: 0.9rem; margin-bottom: 1.5rem; flex-grow: 1;">
                    A collection of custom-built Streamer.bot extensions for Twitch & YouTube. OBS & Meld overlays, games, utilities and integrations. And the best part? It all runs locally, even the overlays.
                </p>
                <div style="display: flex; flex-direction: column; gap: 10px; width: 100%;">
                    <a href="https://tawmae.xyz/" target="_blank" class="cmd-btn" style="text-decoration: none; font-size: 0.8rem; padding: 10px; width: 100%; box-sizing: border-box;">Website</a>
                    <div style="display: flex; gap: 10px; width: 100%;">
                        <a href="https://www.twitch.tv/tawmae" target="_blank" class="cmd-btn" style="text-decoration: none; font-size: 0.8rem; padding: 10px; flex: 1; background: rgba(255, 255, 255, 0.1); box-shadow: none; border: 1px solid rgba(255, 255, 255, 0.1);">Twitch</a>
                        <a href="https://www.youtube.com/@tawmae" target="_blank" class="cmd-btn" style="text-decoration: none; font-size: 0.8rem; padding: 10px; flex: 1; background: rgba(255, 255, 255, 0.1); box-shadow: none; border: 1px solid rgba(255, 255, 255, 0.1);">YouTube</a>
                    </div>
                </div>
            </div>

            <!-- Mustached Maniac -->
            <div class="card" style="align-items: center; text-align: center; padding: 2rem; display: flex; flex-direction: column;">
                <img src="/images/apps/mm.jpg" alt="Mustached Maniac" style="width: 80px; height: 80px; border-radius: 50%; border: 2px solid var(--accent-pink); box-shadow: 0 0 15px rgba(234, 72, 178, 0.4); object-fit: cover; margin-bottom: 1rem;">
                <h3 style="font-family: 'Inter', sans-serif; font-size: 1.5rem; font-weight: 600; letter-spacing: 0;">Mustached Maniac</h3>
                <p style="color: var(--white-med); font-size: 0.9rem; margin-bottom: 1.5rem; flex-grow: 1;">
                    A highly questionable collection of projects, custom streaming experiments, and developer toolkits.
                </p>
                <div style="display: flex; flex-direction: column; gap: 10px; width: 100%;">
                    <a href="https://mustachedmaniac.com/" target="_blank" class="cmd-btn" style="text-decoration: none; font-size: 0.8rem; padding: 10px; width: 100%; box-sizing: border-box;">Website</a>
                    <div style="display: flex; gap: 10px; width: 100%;">
                        <a href="https://www.twitch.tv/mustached_maniac" target="_blank" class="cmd-btn" style="text-decoration: none; font-size: 0.8rem; padding: 10px; flex: 1; background: rgba(255, 255, 255, 0.1); box-shadow: none; border: 1px solid rgba(255, 255, 255, 0.1);">Twitch</a>
                        <a href="https://www.youtube.com/@mustached_maniac" target="_blank" class="cmd-btn" style="text-decoration: none; font-size: 0.8rem; padding: 10px; flex: 1; background: rgba(255, 255, 255, 0.1); box-shadow: none; border: 1px solid rgba(255, 255, 255, 0.1);">YouTube</a>
                    </div>
                </div>
            </div>

            <!-- VRFlad -->
            <div class="card" style="align-items: center; text-align: center; padding: 2rem; display: flex; flex-direction: column;">
                <img src="/images/apps/vrflad.jpg" alt="VRFlad" style="width: 80px; height: 80px; border-radius: 50%; border: 2px solid var(--accent-pink); box-shadow: 0 0 15px rgba(234, 72, 178, 0.4); object-fit: cover; margin-bottom: 1rem;">
                <h3 style="font-family: 'Inter', sans-serif; font-size: 1.5rem; font-weight: 600; letter-spacing: 0;">VRFlad</h3>
                <p style="color: var(--white-med); font-size: 0.9rem; margin-bottom: 1.5rem; flex-grow: 1;">
                    I enjoy pushing what is possible with technology and I'm particularly passionate about VR. Streaming was never planned, but I love it and have been so fortunate to be able to give back to the amazing streaming community.
                </p>
                <div style="display: flex; flex-direction: column; gap: 10px; width: 100%;">
                    <a href="https://vrflad.com/" target="_blank" class="cmd-btn" style="text-decoration: none; font-size: 0.8rem; padding: 10px; width: 100%; box-sizing: border-box;">Website</a>
                    <div style="display: flex; gap: 10px; width: 100%;">
                        <a href="https://twitch.tv/VRFlad" target="_blank" class="cmd-btn" style="text-decoration: none; font-size: 0.8rem; padding: 10px; flex: 1; background: rgba(255, 255, 255, 0.1); box-shadow: none; border: 1px solid rgba(255, 255, 255, 0.1);">Twitch</a>
                        <a href="https://www.youtube.com/@vrflad" target="_blank" class="cmd-btn" style="text-decoration: none; font-size: 0.8rem; padding: 10px; flex: 1; background: rgba(255, 255, 255, 0.1); box-shadow: none; border: 1px solid rgba(255, 255, 255, 0.1);">YouTube</a>
                    </div>
                </div>
            </div>

        </div>

        <!-- ============================================== -->
        <!-- SECTION 3: OBS MAINTAINERS & PLUGINS           -->
        <!-- ============================================== -->

        <!-- Subheading for OBS Maintainers -->
        <h3 class="section-title" style="font-family: 'Bebas Neue', sans-serif; letter-spacing: 2px; color: var(--accent-orange); text-shadow: 0 0 8px rgba(255, 140, 27, 0.4); border-bottom: 1px solid rgba(255, 255, 255, 0.1); padding-bottom: 0.5rem; margin-bottom: 2rem;">
            OBS Maintainers
        </h3>

        <div class="grid" style="grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 30px; margin-bottom: 4rem;">
            
            <!-- Exeldro -->
            <div class="card" style="align-items: center; text-align: center; padding: 2rem; display: flex; flex-direction: column;">
                <img src="/images/apps/exeldro.png" alt="Exeldro" style="width: 80px; height: 80px; border-radius: 50%; border: 2px solid var(--accent-pink); box-shadow: 0 0 15px rgba(234, 72, 178, 0.4); object-fit: cover; margin-bottom: 1rem;">
                <h3 style="font-family: 'Inter', sans-serif; font-size: 1.5rem; font-weight: 600; letter-spacing: 0;">Exeldro</h3>
                <p style="color: var(--white-med); font-size: 0.9rem; margin-bottom: 1.5rem; flex-grow: 1;">
                    Exeldro is a prominent software developer from the Netherlands, best known for creating dozens of highly popular plugins and tools for OBS Studio.
                </p>
                <div style="display: flex; flex-direction: column; gap: 10px; width: 100%;">
                    <div style="display: flex; gap: 10px; width: 100%;">
                        <a href="https://exeldro.com/" target="_blank" class="cmd-btn" style="text-decoration: none; font-size: 0.8rem; padding: 10px; flex: 1;">Website</a>
                        <a href="https://obsproject.com/forum/resources/authors/exeldro.128836/" target="_blank" class="cmd-btn" style="text-decoration: none; font-size: 0.8rem; padding: 10px; flex: 1; background: rgba(255, 255, 255, 0.1); box-shadow: none; border: 1px solid rgba(255, 255, 255, 0.1);">Resource List</a>
                    </div>
                    <div style="display: flex; gap: 10px; width: 100%;">
                        <a href="https://www.twitch.tv/Exeldro" target="_blank" class="cmd-btn" style="text-decoration: none; font-size: 0.8rem; padding: 10px; flex: 1; background: rgba(255, 255, 255, 0.1); box-shadow: none; border: 1px solid rgba(255, 255, 255, 0.1);">Twitch</a>
                        <a href="https://www.youtube.com/@exeldro" target="_blank" class="cmd-btn" style="text-decoration: none; font-size: 0.8rem; padding: 10px; flex: 1; background: rgba(255, 255, 255, 0.1); box-shadow: none; border: 1px solid rgba(255, 255, 255, 0.1);">YouTube</a>
                    </div>
                </div>
            </div>

            <!-- FiniteSingularity -->
            <div class="card" style="align-items: center; text-align: center; padding: 2rem; display: flex; flex-direction: column;">
                <img src="/images/apps/finite.jpg" alt="FiniteSingularity" style="width: 80px; height: 80px; border-radius: 50%; border: 2px solid var(--accent-pink); box-shadow: 0 0 15px rgba(234, 72, 178, 0.4); object-fit: cover; margin-bottom: 1rem;">
                <h3 style="font-family: 'Inter', sans-serif; font-size: 1.5rem; font-weight: 600; letter-spacing: 0;">FiniteSingularity</h3>
                <p style="color: var(--white-med); font-size: 0.9rem; margin-bottom: 1.5rem; flex-grow: 1;">
                    FiniteSingularity is a developer, former academic, and educator with over 20 years of experience. He is best known in the streaming community for creating popular open-source plugins for OBS Studio.
                </p>
                <div style="display: flex; flex-direction: column; gap: 10px; width: 100%;">
                    <div style="display: flex; gap: 10px; width: 100%;">
                        <a href="https://f15y.com/" target="_blank" class="cmd-btn" style="text-decoration: none; font-size: 0.8rem; padding: 10px; flex: 1;">Website</a>
                        <a href="https://obsproject.com/forum/resources/authors/finitesingularity.370888/" target="_blank" class="cmd-btn" style="text-decoration: none; font-size: 0.8rem; padding: 10px; flex: 1; background: rgba(255, 255, 255, 0.1); box-shadow: none; border: 1px solid rgba(255, 255, 255, 0.1);">Resource List</a>
                    </div>
                    <div style="display: flex; gap: 10px; width: 100%;">
                        <a href="https://www.twitch.tv/finitesingularity" target="_blank" class="cmd-btn" style="text-decoration: none; font-size: 0.8rem; padding: 10px; flex: 1; background: rgba(255, 255, 255, 0.1); box-shadow: none; border: 1px solid rgba(255, 255, 255, 0.1);">Twitch</a>
                        <a href="https://www.youtube.com/@FSingularity" target="_blank" class="cmd-btn" style="text-decoration: none; font-size: 0.8rem; padding: 10px; flex: 1; background: rgba(255, 255, 255, 0.1); box-shadow: none; border: 1px solid rgba(255, 255, 255, 0.1);">YouTube</a>
                    </div>
                </div>
            </div>

        </div>

        <!-- Subheading for OBS Plugins -->
        <h3 class="section-title" style="font-family: 'Bebas Neue', sans-serif; letter-spacing: 2px; color: var(--accent-orange); text-shadow: 0 0 8px rgba(255, 140, 27, 0.4); border-bottom: 1px solid rgba(255, 255, 255, 0.1); padding-bottom: 0.5rem; margin-bottom: 2rem;">
            Essential OBS Plugins
        </h3>

        <!-- Plugins Dense Grid -->
        <div class="grid" style="grid-template-columns: repeat(auto-fill, minmax(220px, 1fr)); gap: 20px;">
            
            <div class="card" style="padding: 1.5rem; display: flex; flex-direction: column; text-align: center;">
                <h4 style="margin: 0; font-size: 1.1rem; color: var(--white-low);">Move</h4>
                <p style="color: var(--accent-orange); font-size: 0.85rem; font-weight: 600; margin: 5px 0 1rem;">By Exeldro</p>
                <a href="https://obsproject.com/forum/resources/move.913/" target="_blank" class="cmd-btn" style="text-decoration: none; font-size: 0.8rem; padding: 8px; width: 100%; box-sizing: border-box; margin-top: auto;">View Plugin</a>
            </div>

            <div class="card" style="padding: 1.5rem; display: flex; flex-direction: column; text-align: center;">
                <h4 style="margin: 0; font-size: 1.1rem; color: var(--white-low);">Source Copy</h4>
                <p style="color: var(--accent-orange); font-size: 0.85rem; font-weight: 600; margin: 5px 0 1rem;">By Exeldro</p>
                <a href="https://obsproject.com/forum/resources/source-copy.1261/" target="_blank" class="cmd-btn" style="text-decoration: none; font-size: 0.8rem; padding: 8px; width: 100%; box-sizing: border-box; margin-top: auto;">View Plugin</a>
            </div>

            <div class="card" style="padding: 1.5rem; display: flex; flex-direction: column; text-align: center;">
                <h4 style="margin: 0; font-size: 1.1rem; color: var(--white-low);">Downstream Keyer</h4>
                <p style="color: var(--accent-orange); font-size: 0.85rem; font-weight: 600; margin: 5px 0 1rem;">By Exeldro</p>
                <a href="https://obsproject.com/forum/resources/downstream-keyer.1254/" target="_blank" class="cmd-btn" style="text-decoration: none; font-size: 0.8rem; padding: 8px; width: 100%; box-sizing: border-box; margin-top: auto;">View Plugin</a>
            </div>

            <div class="card" style="padding: 1.5rem; display: flex; flex-direction: column; text-align: center;">
                <h4 style="margin: 0; font-size: 1.1rem; color: var(--white-low);">Gradient Source</h4>
                <p style="color: var(--accent-orange); font-size: 0.85rem; font-weight: 600; margin: 5px 0 1rem;">By Exeldro</p>
                <a href="https://obsproject.com/forum/resources/gradient-source.1172/" target="_blank" class="cmd-btn" style="text-decoration: none; font-size: 0.8rem; padding: 8px; width: 100%; box-sizing: border-box; margin-top: auto;">View Plugin</a>
            </div>

            <div class="card" style="padding: 1.5rem; display: flex; flex-direction: column; text-align: center;">
                <h4 style="margin: 0; font-size: 1.1rem; color: var(--white-low);">Advanced Masks</h4>
                <p style="color: var(--accent-orange); font-size: 0.85rem; font-weight: 600; margin: 5px 0 1rem;">By FiniteSingularity</p>
                <a href="https://obsproject.com/forum/resources/advanced-masks.1856/" target="_blank" class="cmd-btn" style="text-decoration: none; font-size: 0.8rem; padding: 8px; width: 100%; box-sizing: border-box; margin-top: auto;">View Plugin</a>
            </div>

            <div class="card" style="padding: 1.5rem; display: flex; flex-direction: column; text-align: center;">
                <h4 style="margin: 0; font-size: 1.1rem; color: var(--white-low);">Advanced Scene Switcher</h4>
                <p style="color: var(--accent-orange); font-size: 0.85rem; font-weight: 600; margin: 5px 0 1rem;">By Warmuptill</p>
                <a href="https://obsproject.com/forum/resources/advanced-scene-switcher.395/" target="_blank" class="cmd-btn" style="text-decoration: none; font-size: 0.8rem; padding: 8px; width: 100%; box-sizing: border-box; margin-top: auto;">View Plugin</a>
            </div>

            <div class="card" style="padding: 1.5rem; display: flex; flex-direction: column; text-align: center;">
                <h4 style="margin: 0; font-size: 1.1rem; color: var(--white-low);">Media Controls</h4>
                <p style="color: var(--accent-orange); font-size: 0.85rem; font-weight: 600; margin: 5px 0 1rem;">By Exeldro</p>
                <a href="https://obsproject.com/forum/resources/media-controls.1032/" target="_blank" class="cmd-btn" style="text-decoration: none; font-size: 0.8rem; padding: 8px; width: 100%; box-sizing: border-box; margin-top: auto;">View Plugin</a>
            </div>

            <div class="card" style="padding: 1.5rem; display: flex; flex-direction: column; text-align: center;">
                <h4 style="margin: 0; font-size: 1.1rem; color: var(--white-low);">Tuna</h4>
                <p style="color: var(--accent-orange); font-size: 0.85rem; font-weight: 600; margin: 5px 0 1rem;">By univrsal</p>
                <a href="https://obsproject.com/forum/resources/tuna.843/" target="_blank" class="cmd-btn" style="text-decoration: none; font-size: 0.8rem; padding: 8px; width: 100%; box-sizing: border-box; margin-top: auto;">View Plugin</a>
            </div>

            <div class="card" style="padding: 1.5rem; display: flex; flex-direction: column; text-align: center;">
                <h4 style="margin: 0; font-size: 1.1rem; color: var(--white-low);">Quick Access Utility</h4>
                <p style="color: var(--accent-orange); font-size: 0.85rem; font-weight: 600; margin: 5px 0 1rem;">By FiniteSingularity</p>
