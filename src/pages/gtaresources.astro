---
import Layout from '../layouts/Layout.astro';
---

<Layout title="GTA Resources | 2 Smokin' Barrels">
    <main class="container">
        <h1 class="page-title">GTA Online Resources</h1>
        <p class="page-subtitle" style="text-align: center; color: var(--white-med); margin-bottom: 3rem;">
            Essential tools and community hubs for Los Santos.
        </p>

        {/* Updated "Widget" style for Gun Van Location */}
        <div id="gun-van-banner" class="resource-card nazar-hero" style="width: 90%; margin: 0 auto 3rem auto; border: 1px solid var(--accent-pink); border-radius: 16px; box-shadow: 0 0 15px rgba(234, 72, 178, 0.2);">
            <div class="nazar-image-container">
                <i id="gun-van-icon" class="fa-solid fa-van-shuttle" style="font-size: 3rem; color: var(--accent-orange);"></i>
                <img id="gun-van-image" src="" alt="Gun Van Map" style="display: none; width: 100%; height: 100%; object-fit: cover;">
            </div>
            <div class="nazar-info">
                <h3 style="font-family: 'Bebas Neue', sans-serif; font-size: 2rem; color: var(--accent-orange); margin-bottom: 10px; text-shadow: 0 0 8px rgba(255, 140, 27, 0.4);">Daily Gun Van Location</h3>
                <p id="gun-van-location-text" style="color: var(--white-low);">Updating location data...</p>
            </div>
        </div>

        <div class="resource-grid">
            <a href="https://map.stateofleonida.net/?lang=en" class="resource-card" target="_blank" rel="noopener noreferrer">
                <div class="resource-thumb" style="background-image: url('/images/thumb-vimap.jpg');"></div>
                <div class="resource-info">
                    <h3 style="font-family: 'Bebas Neue', sans-serif; font-size: 1.6rem; color: var(--accent-orange);">GTA VI Mapping</h3>
                    <p>The GTA VI Mapping Project.</p>
                </div>
            </a>

            <a href="https://vi-text-generator.vercel.app/" class="resource-card" target="_blank" rel="noopener noreferrer">
                <div class="resource-thumb" style="background-image: url('/images/thumb-textgen.jpg');"></div>
                <div class="resource-info">
                    <h3 style="font-family: 'Bebas Neue', sans-serif; font-size: 1.6rem; color: var(--accent-orange);">VI Text Generator</h3>
                    <p>Generate creative text and logos in the distinct style of GTA VI.</p>
                </div>
            </a>

            <a href="https://rockstarintel.com/" class="resource-card" target="_blank" rel="noopener noreferrer">
                <div class="resource-thumb" style="background-image: url('/images/thumb-intel.jpg');"></div>
                <div class="resource-info">
                    <h3 style="font-family: 'Bebas Neue', sans-serif; font-size: 1.6rem; color: var(--accent-orange);">Rockstar Intel</h3>
                    <p>Stay updated with the latest news, updates, and community guides for all Rockstar titles.</p>
                </div>
            </a>

            <a href="https://gtaweb.eu/" class="resource-card" target="_blank" rel="noopener noreferrer">
                <div class="resource-thumb" style="background-image: url('/images/thumb-gtaweb.jpg');"></div>
                <div class="resource-info">
                    <h3 style="font-family: 'Bebas Neue', sans-serif; font-size: 1.6rem; color: var(--accent-orange);">GTAWeb Map</h3>
                    <p>The definitive interactive map for collectibles and points of interest in GTA Online.</p>
                </div>
            </a>

            <a href="https://gta.wiki/" class="resource-card" target="_blank" rel="noopener noreferrer">
                <div class="resource-thumb" style="background-image: url('/images/thumb-gtawiki.jpg');"></div>
                <div class="resource-info">
                    <h3 style="font-family: 'Bebas Neue', sans-serif; font-size: 1.6rem; color: var(--accent-orange);">GTA Wiki</h3>
                    <p>The most comprehensive encyclopedia for all lore, vehicles, and gameplay mechanics.</p>
                </div>
            </a>

            <a href="https://gtaforums.com/" class="resource-card" target="_blank" rel="noopener noreferrer">
                <div class="resource-thumb" style="background-image: url('/images/thumb-gtaforums.jpg');"></div>
                <div class="resource-info">
                    <h3 style="font-family: 'Bebas Neue', sans-serif; font-size: 1.6rem; color: var(--accent-orange);">GTAForums</h3>
                    <p>Join the largest community discussion board for technical troubleshooting and community events.</p>
                </div>
            </a>

            <a href="https://amethxst.dev/" class="resource-card" target="_blank" rel="noopener noreferrer">
                <div class="resource-thumb" style="background-image: url('/images/thumb-amethyst.jpg');"></div>
                <div class="resource-info">
                    <h3 style="font-family: 'Bebas Neue', sans-serif; font-size: 1.6rem; color: var(--accent-orange);">Amethxst.dev</h3>
                    <p>Custom tools and utilities for GTA Online players and creators.</p>
                </div>
            </a>

            <a href="https://docs.google.com/spreadsheets/d/1CV8d9A1x55ZDoJ-Q2Bslkek_K6UbqaBzvODG52HHHCM/edit?gid=0" class="resource-card" target="_blank" rel="noopener noreferrer">
                <div class="resource-thumb" style="background-image: url('/images/thumb-livery.jpg');"></div>
                <div class="resource-info">
                    <h3 style="font-family: 'Bebas Neue', sans-serif; font-size: 1.6rem; color: var(--accent-orange);">Livery Shenanigans Spreadsheet</h3>
                    <p>A community spreadsheet showing what Liveries are available on each car and DLC vehicle sets/groups.</p>
                </div>
            </a>
        </div>
        
        <div style="margin-top: 4rem; text-align: center;">
            <a href="/" style="color: var(--accent-pink); text-decoration: none; font-weight: 600; text-transform: uppercase; letter-spacing: 1px;">&larr; Back to Home</a>
        </div>
    </main>
</Layout>