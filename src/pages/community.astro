            </div>

            <!-- Exzumi -->
            <div class="card" style="align-items: center; text-align: center;">
                <img src="/images/community/exzumi.jpg" alt="Exzumi" style="border-radius: 50%; width: 100px; height: 100px; border: 2px solid var(--accent-red); margin-bottom: 1rem; object-fit: cover;">
                <h3>Exzumi</h3>
                <p style="color: var(--white-med); font-size: 0.95rem; margin-bottom: 1rem; flex-grow: 1;">
                    Dive into engaging gameplay and chill streams. Don't miss out on the latest uploads!
                </p>
                
                <!-- Stream Indicators -->
                <div style="display: flex; justify-content: center; gap: 12px; flex-wrap: wrap; margin-bottom: 1.5rem; font-size: 0.8rem; background: rgba(0,0,0,0.4); padding: 8px; border-radius: 4px; border: 1px solid #333; width: 100%; box-sizing: border-box;">
                    <span style="color: var(--white-med);">Face: <span style="color: var(--accent-red); font-weight: bold;">&#10007;</span></span>
                    <span style="color: var(--white-med);">Mic: <span style="color: var(--accent-red); font-weight: bold;">&#10007;</span></span>
                    <span style="color: var(--white-med);">Integrations: <span style="color: var(--accent-red); font-weight: bold;">None</span></span>
                </div>

                <a href="https://www.youtube.com/@Exzumi" target="_blank" class="cmd-btn" style="text-decoration: none; font-size: 0.8rem; padding: 10px; width: 100%; box-sizing: border-box;">YouTube Channel</a>
            </div>

            <!-- High Guy Gaming -->
            <div class="card" style="align-items: center; text-align: center;">
                <img src="/images/community/highguy.jpg" alt="High Guy Gaming" style="border-radius: 50%; width: 100px; height: 100px; border: 2px solid var(--accent-red); margin-bottom: 1rem; object-fit: cover;">
                <h3>High Guy Gaming</h3>
                <p style="color: var(--white-med); font-size: 0.95rem; margin-bottom: 1rem; flex-grow: 1;">
                    High-energy gameplay and incredible interactions powered by custom stream integrations.
                </p>
                
                <!-- Stream Indicators -->
                <div style="display: flex; justify-content: center; gap: 12px; flex-wrap: wrap; margin-bottom: 1.5rem; font-size: 0.8rem; background: rgba(0,0,0,0.4); padding: 8px; border-radius: 4px; border: 1px solid #333; width: 100%; box-sizing: border-box;">
                    <span style="color: var(--white-low);">Face: <span style="color: #00ff00; font-weight: bold;">&#10003;</span></span>
                    <span style="color: var(--white-low);">Mic: <span style="color: #00ff00; font-weight: bold;">&#10003;</span></span>
