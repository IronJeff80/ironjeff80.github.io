---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Contact Us | 2 Smokin' Barrels">
    <main class="container" style="max-width: 600px; margin: 4rem auto; padding: 2rem; background: var(--card-bg); border: 1px solid rgba(255, 255, 255, 0.05); border-radius: 16px; backdrop-filter: blur(12px);">
        <h1 class="page-title" style="font-family: 'Mr Dafoe', cursive; font-size: 3.5rem; color: var(--accent-pink); text-align: center; margin-bottom: 1rem; text-shadow: 0 0 10px rgba(234, 72, 178, 0.6);">Contact Us</h1>
        <p style="color: var(--white-med); margin-bottom: 2rem; text-align: center;">
            Have a question, feedback, or a request? Use the form below to reach out. 
            We try to respond to all community inquiries within 48 hours.
        </p>

        <form action="https://api.web3forms.com/submit" method="POST" style="display: flex; flex-direction: column; gap: 1rem;">
            
            <input type="hidden" name="access_key" value="ac03e2e3-2ea1-487c-ae65-3301bf19416e">
            <input type="hidden" name="redirect" value="https://2smokinbarrels.com/thank-you">

            <label style="color: var(--accent-orange); font-family: 'Bebas Neue', sans-serif; letter-spacing: 1px;">Name</label>
            <input type="text" name="name" required style="padding: 12px; border-radius: 8px; border: 1px solid rgba(255, 255, 255, 0.1); background: rgba(0, 0, 0, 0.3); color: white;">

            <label style="color: var(--accent-orange); font-family: 'Bebas Neue', sans-serif; letter-spacing: 1px;">Email</label>
            <input type="email" name="email" required style="padding: 12px; border-radius: 8px; border: 1px solid rgba(255, 255, 255, 0.1); background: rgba(0, 0, 0, 0.3); color: white;">

            <label style="color: var(--accent-orange); font-family: 'Bebas Neue', sans-serif; letter-spacing: 1px;">Message</label>
            <textarea name="message" rows="5" required style="padding: 12px; border-radius: 8px; border: 1px solid rgba(255, 255, 255, 0.1); background: rgba(0, 0, 0, 0.3); color: white;"></textarea>

            <button type="submit" class="cmd-btn" style="margin-top: 1rem;">
                Send Message
            </button>
        </form>
    </main>
</Layout>