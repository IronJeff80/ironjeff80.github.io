<footer class="site-footer">
    <div class="footer-social">
        <a href="https://youtube.com/@2smokinbarrels" target="_blank"><img src="/icons/youtube.png" alt="YouTube"></a>
        <a href="https://discord.gg/AWC6PNA2mK" target="_blank"><img src="/icons/discord.png" alt="Discord"></a>
        <a href="https://x.com/2_SmokinBarrels" target="_blank"><img src="/icons/x.png" alt="X"></a>
        <a href="https://www.facebook.com/2smokinbarrelsgaming/" target="_blank"><img src="/icons/facebook.png" alt="Facebook"></a>
        <a href="https://www.patreon.com/c/2SmokinBarrels" target="_blank"><img src="/icons/patreon.png" alt="Patreon"></a>
        <a href="https://github.com/ironjeff80" target="_blank"><img src="/icons/github.png" alt="GitHub"></a>
    </div>

    <div class="footer-copyright">
        &copy; 2026 In Smokin' We Trust.
    </div>

    <div class="footer-legal">
        <a href="/legal/tos/">TOS</a> 
        <span class="divider">|</span> 
        <a href="/legal/privacy/">Privacy</a>
    </div>
</footer>

<style>
    /* 📱 MOBILE FIRST LAYOUT */
    .site-footer {
        padding: 0.5rem 5%;
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
        align-items: center;
        border-top: 2px solid var(--accent-pink);
    }

    .footer-social {
        display: flex;
        gap: 15px;
        align-items: center;
        justify-content: center;
    }

    /* Locks the icon size to 20px */
    .footer-social img {
        width: 20px !important; 
        height: auto;
    }

    /* Locks the orange copyright color */
    .footer-copyright {
        text-align: center;
        font-size: 0.8rem;
        font-weight: 700;
        color: var(--accent-orange);
    }

    /* Locks the pink legal links */
    .footer-legal {
        text-align: center;
        font-size: 0.8rem;
    }

    .footer-legal a {
        color: var(--accent-pink) !important;
        text-decoration: none;
        margin: 0 10px;
    }

    .footer-legal .divider {
        color: var(--accent-pink);
    }

    /* 🖥️ DESKTOP LAYOUT (Applies to screens 768px and wider) */
    @media (min-width: 768px) {
        .site-footer {
            display: grid;
            grid-template-columns: 1fr auto 1fr;
            gap: 0;
        }

        .footer-social {
            justify-content: flex-start;
        }

        .footer-legal {
            text-align: right;
        }
    }
</style>